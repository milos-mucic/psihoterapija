---
import SeoHead from "@/components/astro/seo/SeoHead.astro";
import { adminConfig } from "@/lib/config/admin";
import "@/styles/global.css";

type Props = {
  title: string;
  description?: string;
};

const { title, description = "Skriveni admin segment za blog i prijave." } = Astro.props;
---

<!doctype html>
<html lang="sr-Latn-RS">
  <head>
    <SeoHead title={title} description={description} canonicalPath={Astro.url.pathname} />
  </head>
  <body class="admin-shell">
    <main class="section">
      <div class="container">
        <div class="page-grid">
          <div class="card" style="padding: 1.2rem;">
            <div
              style="display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;"
            >
              <div>
                <p class="eyebrow">Hidden admin</p>
                <h1 style="margin: 0; font-size: 1.8rem;">Ikar admin</h1>
              </div>
              <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
                <a class="button-secondary" href={`${adminConfig.basePath}/`}>
                  Dashboard
                </a>
                <form action="/api/admin/logout" method="post">
                  <button class="button-ghost" type="submit">Odjava</button>
                </form>
              </div>
            </div>
          </div>
          <slot />
        </div>
      </div>
    </main>
  </body>
</html>
