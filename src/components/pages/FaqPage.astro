---
import PageBanner from "@/components/sections/PageBanner.astro";
import FaqAccordionSection from "@/components/sections/FaqAccordionSection.astro";
import { pageContentService } from "@/features/page-content/services/page-content.service";
import type { SiteLocale } from "@/lib/config/site";

type Props = {
  locale: SiteLocale;
};

const { locale } = Astro.props;
const content = await pageContentService.getFaqPageData(locale);
---

<PageBanner {...content.banner} sectionId="faq-banner" />

<FaqAccordionSection
  items={content.items}
  image={content.faqImage}
  imageLoading="eager"
  sectionClass="page-section--soft faq-page__accordion-section"
  sectionId="faq-items"
/>

<style>
  :global(#faq-items) {
    padding-top: clamp(3.4rem, 7vw, 4.8rem);
  }

  .faq-page__accordion-section :global(.faq-accordion__media) {
    min-height: clamp(15rem, 28vw, 20rem);
  }
</style>
