---
import FaqAccordionSection from "@/components/sections/FaqAccordionSection.astro";
import { AppointmentForm } from "@/components/components/AppointmentForm";
import { getDictionary } from "@/features/i18n/translate";
import { pageContentService } from "@/features/page-content/services/page-content.service";
import type { SiteLocale } from "@/lib/config/site";

type Props = {
  locale: SiteLocale;
};

const { locale } = Astro.props;
const content = await pageContentService.getAppointmentPageData(locale);
const dictionary = getDictionary(locale);
---

<section
  id="appointment-booking"
  class="home-section home-section--tight appointment-page__booking"
>
  <div class="container">
    <div class="home-booking appointment-page__booking-grid">
      <div class="home-booking__intro" data-reveal="up">
        <h2>{content.formTitle}</h2>
        <div class="appointment-page__intro-copy richtext-shell" set:html={content.introCopy} />
        <div class="home-booking__formats">
          {content.formats.map((format) => <span class="home-pill">{format}</span>)}
        </div>
      </div>

      <div data-reveal="up" style="--reveal-delay: 90ms;">
        <AppointmentForm
          client:load
          locale={locale}
          labels={dictionary.forms}
          formatLabel={content.formatLabel}
          formats={content.formats}
        />
      </div>
    </div>
  </div>
</section>

<FaqAccordionSection
  items={content.faqs}
  image={content.faqImage}
  sectionClass="page-section--soft appointment-page__accordion-section"
  sectionId="appointment-faq"
/>

<style>
  .appointment-page__booking {
    padding-top: 0.5rem;
  }

  .appointment-page__booking-grid {
    gap: clamp(1.4rem, 4vw, 2.1rem);
  }

  .appointment-page__intro-copy :global(p),
  .appointment-page__intro-copy :global(ul),
  .appointment-page__intro-copy :global(ol) {
    margin: 0;
    line-height: 1.7;
  }

  .appointment-page__booking :global(.stack-form) {
    padding: 1.9rem;
    border-radius: 1rem;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 18px 44px rgba(16, 47, 48, 0.08);
  }

  @media (max-width: 720px) {
    .appointment-page__booking :global(.stack-form) {
      padding: 1.2rem;
    }
  }
</style>
