---
import ContactForm from "@/components/components/ContactForm.astro";
import PageBanner from "@/components/sections/PageBanner.astro";
import { getDictionary } from "@/features/i18n/translate";
import { pageContentService } from "@/features/page-content/services/page-content.service";
import type { SiteLocale } from "@/lib/config/site";

type Props = {
  locale: SiteLocale;
  content?: Awaited<ReturnType<typeof pageContentService.getContactPageData>>;
};

const { locale, content: previewContent } = Astro.props;
const content = previewContent ?? (await pageContentService.getContactPageData(locale));
const dictionary = getDictionary(locale);
---

<PageBanner {...content.banner} />

<section id="contact-details" class="page-section">
  <div class="container">
    <div class="contact-layout">
      <div class="contact-details">
        <h2>{content.introTitle}</h2>
        <div class="richtext-shell" set:html={content.introCopy} />

        <div class="contact-details__grid">
          <article class="contact-details__card" data-reveal="up">
            <h3>{content.contactLabels.phone}</h3>
            <a
              class="page-inline-link page-inline-link--plain"
              href={`tel:${content.phone.replace(/\s+/g, "")}`}
            >
              {content.phone}
            </a>
          </article>

          <article class="contact-details__card" data-reveal="up" style="--reveal-delay: 80ms;">
            <h3>{content.contactLabels.email}</h3>
            <a class="page-inline-link page-inline-link--plain" href={`mailto:${content.email}`}>
              {content.email}
            </a>
          </article>
        </div>

        <div class="contact-socials" data-reveal="up" style="--reveal-delay: 140ms;">
          <h3>{content.contactLabels.socials}</h3>
          <div class="contact-socials__icons">
            {
              content.socialLinks.map((link) => (
                <a href={link.href} target="_blank" rel="noreferrer" aria-label={link.label}>
                  {
                    link.platform === "facebook" ? (
                      <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M13.5 21v-7h2.4l.4-3h-2.8V9.2c0-.9.3-1.6 1.7-1.6H16V4.9c-.4-.1-1.2-.2-2.2-.2-2.2 0-3.8 1.4-3.8 4V11H7.5v3H10v7h3.5Z" />
                      </svg>
                    ) : link.platform === "instagram" ? (
                      <svg
                        aria-hidden="true"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                      >
                        <rect x="3.5" y="3.5" width="17" height="17" rx="5"></rect>
                        <circle cx="12" cy="12" r="3.75"></circle>
                        <circle cx="17.2" cy="6.8" r="1"></circle>
                      </svg>
                    ) : (
                      <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M6.9 8.2A1.9 1.9 0 1 1 7 4.4a1.9 1.9 0 0 1-.1 3.8ZM5.2 9.8h3.5V20H5.2V9.8Zm5.6 0H14v1.4h.1c.5-.9 1.7-1.8 3.4-1.8 3.6 0 4.3 2.4 4.3 5.5V20h-3.5v-4.6c0-1.1 0-2.5-1.5-2.5s-1.8 1.2-1.8 2.4V20h-3.5V9.8Z" />
                      </svg>
                    )
                  }
                </a>
              ))
            }
          </div>
        </div>
      </div>

      <div class="page-form-shell page-form-shell--contact" data-reveal="right">
        <h2>{content.formTitle}</h2>
        <ContactForm locale={locale} labels={dictionary.forms} />
      </div>
    </div>
  </div>
</section>

<section id="contact-offices" class="page-section page-section--soft">
  <div class="container">
    <div class="page-section__header">
      <h2>{content.officesTitle}</h2>
      <div class="richtext-shell" set:html={content.officesCopy} />
    </div>

    <div class="office-gallery">
      {
        content.officeGallery.map((image, index) => (
          <article
            class="office-gallery__card"
            data-reveal="up"
            style={`--reveal-delay: ${index * 90}ms;`}
          >
            <img
              src={image}
              alt={`${dictionary.common.officeRoom} ${index + 1}`}
              loading="lazy"
              data-image-component
            />
            <div class="office-gallery__meta">
              <h3>
                {dictionary.common.officeRoom} {index + 1}
              </h3>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
