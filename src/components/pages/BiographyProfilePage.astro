---
import PageBanner from "@/components/sections/PageBanner.astro";
import { pageContentService } from "@/features/page-content/services/page-content.service";
import type { SiteLocale } from "@/lib/config/site";

type Props = {
  locale: SiteLocale;
  slug: string;
};

const { locale, slug } = Astro.props;
const content = await pageContentService.getBiographyProfilePageData(locale, slug);

if (!content) {
  throw new Error(`Missing biography profile data for slug: ${slug}`);
}
---

<div class="biography-profile-page__banner">
  <PageBanner {...content.banner} />
</div>

<section class="page-section biography-profile-page__intro">
  <div class="container">
    <div class="biography-profile-page__grid">
      <div class="biography-profile-page__media" data-reveal="left">
        <img src={content.profile.image} alt={content.profile.title} loading="lazy" />
      </div>

      <div class="biography-profile-page__copy" data-reveal="right" style="--reveal-delay: 90ms;">
        <p class="biography-profile-page__role">{content.profile.role}</p>
        <h1>{content.profile.title}</h1>
        <div class="biography-profile-page__summary" set:html={content.profile.summary} />

        <ul class="biography-profile-page__tags">
          {content.profile.highlights.map((tag) => <li>{tag}</li>)}
        </ul>

        <div class="biography-profile-page__actions">
          <a class="button-ghost" href={content.backHref}>{content.backLabel}</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="page-section page-section--soft biography-profile-page__body">
  <div class="container container--narrow">
    <div class="biography-profile-page__body-card" data-reveal="up">
      <div set:html={content.profile.body} />
    </div>
  </div>
</section>

{
  content.relatedProfiles.length > 0 ? (
    <section class="home-section home-section--tight">
      <div class="container">
        <div class="home-heading-row" data-reveal="up">
          <div class="home-heading-copy">
            <h2>{content.relatedTitle}</h2>
          </div>
          <a class="home-button" href={content.backHref}>
            {content.backLabel}
          </a>
        </div>

        <div class="biography-profile-page__related-grid">
          {content.relatedProfiles.map((profile, index) => (
            <a
              class="biography-profile-page__related-card"
              href={profile.href}
              data-reveal="up"
              style={`--reveal-delay: ${index * 70}ms;`}
            >
              <img src={profile.image} alt={profile.title} loading="lazy" />
              <p class="biography-profile-page__related-role">{profile.role}</p>
              <h3>{profile.title}</h3>
              <div set:html={profile.summary} />
            </a>
          ))}
        </div>
      </div>
    </section>
  ) : null
}

<style>
  .biography-profile-page__grid {
    display: grid;
    grid-template-columns: minmax(18rem, 28rem) minmax(0, 1fr);
    gap: clamp(1.5rem, 5vw, 3rem);
    align-items: center;
  }

  .biography-profile-page__media {
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid var(--line);
    box-shadow: 0 22px 52px rgba(16, 47, 48, 0.12);
  }

  .biography-profile-page__media img {
    width: 100%;
    height: 100%;
    min-height: 22rem;
    object-fit: cover;
    display: block;
  }

  .biography-profile-page__copy {
    display: grid;
    gap: 1rem;
  }

  .biography-profile-page__role,
  .biography-profile-page__related-role {
    margin: 0;
    color: var(--primary);
    font-size: 0.86rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .biography-profile-page__copy h1 {
    font-size: clamp(2.3rem, 5vw, 4rem);
    line-height: 1.04;
  }

  .biography-profile-page__summary {
    color: var(--foreground);
    font-size: 1.04rem;
    line-height: 1.75;
  }

  .biography-profile-page__summary :global(p),
  .biography-profile-page__summary :global(ul),
  .biography-profile-page__summary :global(ol),
  .biography-profile-page__body-card :global(p),
  .biography-profile-page__body-card :global(ul),
  .biography-profile-page__body-card :global(ol) {
    margin: 0;
    line-height: 1.75;
  }

  .biography-profile-page__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .biography-profile-page__tags li {
    padding: 0.4rem 0.65rem;
    border-radius: 999px;
    border: 1px solid rgba(22, 60, 61, 0.12);
    background: rgba(22, 60, 61, 0.04);
    color: var(--foreground);
    font-size: 0.84rem;
    line-height: 1.3;
  }

  .biography-profile-page__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .biography-profile-page__body-card {
    display: grid;
    gap: 1rem;
    padding: clamp(1.35rem, 3vw, 2rem);
    border: 1px solid var(--line);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 18px 44px rgba(16, 47, 48, 0.08);
  }

  .biography-profile-page__body-card p {
    color: var(--foreground);
    line-height: 1.75;
  }

  .biography-profile-page__related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 1rem;
  }

  .biography-profile-page__related-card {
    display: grid;
    gap: 0.7rem;
    border-radius: 1rem;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 18px 44px rgba(16, 47, 48, 0.08);
    overflow: hidden;
    transition:
      transform 220ms ease,
      box-shadow 220ms ease,
      border-color 220ms ease;
  }

  .biography-profile-page__related-card:hover {
    color: inherit;
    transform: translateY(-3px);
    border-color: rgb(var(--primary-rgb) / 0.18);
    box-shadow: 0 22px 52px rgba(16, 47, 48, 0.12);
  }

  .biography-profile-page__related-card img {
    width: 100%;
    aspect-ratio: 16 / 11;
    object-fit: cover;
  }

  .biography-profile-page__related-card > :global(*) {
    margin-inline: 1rem;
  }

  .biography-profile-page__related-card img:first-child {
    margin: 0;
  }

  .biography-profile-page__related-card h3 {
    font-size: 1.3rem;
    line-height: 1.15;
  }

  .biography-profile-page__related-card p:last-child {
    margin-bottom: 1rem;
    color: var(--foreground);
    line-height: 1.6;
  }

  @media (max-width: 960px) {
    .biography-profile-page__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
