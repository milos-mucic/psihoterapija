---
import PageBanner from "@/components/sections/PageBanner.astro";
import { localizePath } from "@/features/i18n/locale";
import { getDictionary } from "@/features/i18n/translate";
import { blogService } from "@/features/blog/services/blog.service";
import { pageContentService } from "@/features/page-content/services/page-content.service";
import type { SiteLocale } from "@/lib/config/site";

type Props = {
  locale: SiteLocale;
  content?: Awaited<ReturnType<typeof pageContentService.getScopePageData>>;
};

const { locale, content: previewContent } = Astro.props;
const content = previewContent ?? (await pageContentService.getScopePageData(locale));
const dictionary = getDictionary(locale);
const posts = (await blogService.listPublishedPosts(locale)).slice(0, 3);
const scopeTabListLabel = dictionary.common.scopeTabList;
const scopeTabsPrevLabel = dictionary.common.scopeTabPrev;
const scopeTabsNextLabel = dictionary.common.scopeTabNext;
---

<div id="scope-banner" class="scope-page__banner">
  <PageBanner {...content.banner} />
</div>

<section id="scope-tabs" class="page-section scope-page__tabs-section">
  <div class="container">
    <div class="scope-page__tabs" data-scope-tabs>
      <h2 class="scope-page__section-heading">{content.scopeTitle}</h2>
      <div class="scope-page__tabs-carousel" data-reveal="up">
        <button
          type="button"
          class="scope-page__tabs-nav"
          data-scope-tabs-prev
          aria-label={scopeTabsPrevLabel}
        >
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
            <path
              d="M14.5 6.5L9 12L14.5 17.5"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.9"></path>
          </svg>
        </button>

        <div
          class="scope-page__tabs-menu"
          role="tablist"
          aria-label={content.scopeTitle}
          data-scope-tabs-track
        >
          {
            content.tabs.map((tab, index) => (
              <button
                type="button"
                class:list={["scope-page__tab", index === 0 && "is-active"]}
                role="tab"
                id={`scope-tab-${tab.id}`}
                aria-controls={`scope-panel-${tab.id}`}
                aria-selected={index === 0 ? "true" : "false"}
                tabindex={index === 0 ? "0" : "-1"}
                data-scope-tab-trigger
                data-tab-id={tab.id}
                style={`--reveal-delay: ${index * 70}ms;`}
              >
                <span class="scope-page__tab-icon-shell" aria-hidden="true">
                  <img
                    class="scope-page__tab-icon"
                    src={tab.icon}
                    alt=""
                    loading="lazy"
                    data-image-component
                  />
                </span>
                <span class="scope-page__tab-copy">
                  <span class="scope-page__tab-label">{tab.label}</span>
                  <span class="scope-page__tab-meta">{tab.tabMeta}</span>
                </span>
              </button>
            ))
          }
        </div>

        <button
          type="button"
          class="scope-page__tabs-nav"
          data-scope-tabs-next
          aria-label={scopeTabsNextLabel}
        >
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
            <path
              d="M9.5 6.5L15 12L9.5 17.5"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.9"></path>
          </svg>
        </button>
      </div>

      <div class="scope-page__tab-panels">
        {
          content.tabs.map((tab, tabIndex) => (
            <section
              class="scope-page__tab-panel"
              role="tabpanel"
              id={`scope-panel-${tab.id}`}
              aria-labelledby={`scope-tab-${tab.id}`}
              hidden={tabIndex !== 0}
              data-scope-tab-panel
              data-tab-id={tab.id}
            >
              <article class="scope-page__tab-showcase" data-reveal="up">
                <div class="scope-page__tab-summary">
                  <div class="scope-page__tab-summary-card">
                    <div class="scope-page__tab-summary-top">
                      <span class="scope-page__tab-summary-eyebrow">{tab.panelEyebrow}</span>
                      <div class="scope-page__tab-summary-head">
                        <span class="scope-page__tab-summary-icon-shell" aria-hidden="true">
                          <img
                            class="scope-page__tab-summary-icon"
                            src={tab.icon}
                            alt=""
                            loading="lazy"
                            data-image-component
                          />
                        </span>
                        <div class="scope-page__tab-summary-title-wrap">
                          <p class="scope-page__tab-summary-kicker">{tab.label}</p>
                          <h3 class="scope-page__tab-item-title">{tab.summaryTitle}</h3>
                        </div>
                      </div>
                    </div>

                    <div class="scope-page__tab-summary-art">
                      <img
                        src={tab.detailImage}
                        alt={tab.summaryTitle}
                        loading="lazy"
                        data-image-component
                      />
                    </div>

                    <div
                      class="scope-page__tab-item-copy richtext-shell"
                      set:html={tab.summaryCopy}
                    />
                    <div class="scope-page__tab-lead richtext-shell" set:html={tab.detailLead} />

                    <div class="scope-page__tab-summary-footer">
                      <div class="scope-page__tab-stat">
                        <strong>{String(tab.items.length).padStart(2, "0")}</strong>
                        <span>{tab.panelStatLabel}</span>
                      </div>
                      <a class="home-button scope-page__tab-cta" href={tab.href}>
                        {tab.panelCtaLabel}
                      </a>
                    </div>
                  </div>

                  <div class="scope-page__tab-points-shell">
                    <div class="scope-page__tab-points-head">
                      <p>{scopeTabListLabel}</p>
                    </div>
                    <div class="scope-page__tab-points-grid">
                      {tab.items.map((item, itemIndex) => (
                        <article class="scope-page__tab-point">
                          <span class="scope-page__tab-point-index">
                            {String(itemIndex + 1).padStart(2, "0")}
                          </span>
                          <h4>{item.title}</h4>
                          <div
                            class="scope-page__tab-point-copy richtext-shell"
                            set:html={item.copy}
                          />
                        </article>
                      ))}
                    </div>
                  </div>
                </div>
              </article>
            </section>
          ))
        }
      </div>
    </div>
  </div>
</section>

<section id="scope-focus" class="page-section scope-page__focus-section">
  <div class="container">
    <div class="scope-page__focus-grid">
      <img
        src={content.focusImage}
        alt=""
        class="scope-page__focus-image"
        data-image-component
        data-reveal="left"
      />
      <div class="scope-page__focus-content" data-reveal="right" style="--reveal-delay: 90ms;">
        <h2>{content.focusTitle}</h2>
        <div class="scope-page__focus-copy richtext-shell" set:html={content.focusCopy} />
        <div
          class="scope-page__focus-secondary richtext-shell"
          set:html={content.focusSecondaryCopy}
        />
        <a class="home-button" href={content.focusCtaHref}>
          {content.focusCtaLabel}
        </a>
      </div>
    </div>
  </div>
</section>

<section id="scope-blog" class="home-section home-section--tight">
  <div class="container">
    <div class="home-heading-row home-heading-row--blog" data-reveal="up">
      <div class="home-heading-copy">
        <h2>{content.recentTitle}</h2>
        <div class="scope-page__recent-copy richtext-shell" set:html={content.recentCopy} />
      </div>
      <a class="home-button" href={content.recentHref}>{content.recentLabel}</a>
    </div>

    {
      posts.length > 0 ? (
        <div class="home-card-grid home-card-grid--blog">
          {posts.map((post, index) => (
            <article
              class="home-blog-card"
              data-reveal="up"
              style={`--reveal-delay: ${index * 90}ms;`}
            >
              <a class="home-blog-card__media" href={localizePath(locale, `/blog/${post.slug}/`)}>
                <img
                  src={post.coverImage ?? "/legacy/images/Blog-1_1Blog 1.webp"}
                  alt={post.title}
                  loading="lazy"
                  data-image-component
                />
              </a>
              <div class="home-blog-card__body">
                <div class="home-post-meta">
                  <span>
                    {post.publishedAt.toLocaleDateString(
                      locale === "sr-cyrl" ? "sr-Cyrl-RS" : "sr-RS",
                    )}
                  </span>
                  <span>&bull;</span>
                  <span>{post.tags.join(", ") || dictionary.blog.defaultTag}</span>
                </div>
                <div class="home-blog-card__copy">
                  <h3>{post.title}</h3>
                  <div class="home-blog-card__excerpt" set:html={post.excerpt} />
                </div>
                <a
                  class="home-blog-card__action"
                  href={localizePath(locale, `/blog/${post.slug}/`)}
                >
                  <span>{dictionary.blog.readMoreLabel}</span>
                  <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
                    <path
                      d="M7 17L17 7M9 7H17V15"
                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.9"
                    />
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="home-card" data-reveal="up">
          <p>{content.recentEmpty}</p>
        </div>
      )
    }
  </div>
</section>

<script>
  (() => {
    const setupScopeTabs = () => {
      document.querySelectorAll("[data-scope-tabs]").forEach((tabsRoot) => {
        if (!(tabsRoot instanceof HTMLElement) || tabsRoot.dataset.bound === "true") {
          return;
        }

        const triggers = Array.from(tabsRoot.querySelectorAll("[data-scope-tab-trigger]"));
        const panels = Array.from(tabsRoot.querySelectorAll("[data-scope-tab-panel]"));
        const prevButton = tabsRoot.querySelector("[data-scope-tabs-prev]");
        const nextButton = tabsRoot.querySelector("[data-scope-tabs-next]");

        const setActiveTab = (tabId, options = {}) => {
          const { scroll = true } = options;

          triggers.forEach((trigger) => {
            if (!(trigger instanceof HTMLElement)) return;

            const isActive = trigger.dataset.tabId === tabId;
            trigger.classList.toggle("is-active", isActive);
            trigger.setAttribute("aria-selected", isActive ? "true" : "false");
            trigger.setAttribute("tabindex", isActive ? "0" : "-1");

            if (isActive && scroll) {
              trigger.scrollIntoView({
                behavior: "smooth",
                block: "nearest",
                inline: "center",
              });
            }
          });

          panels.forEach((panel) => {
            if (!(panel instanceof HTMLElement)) return;
            panel.hidden = panel.dataset.tabId !== tabId;
          });
        };

        const activateAtIndex = (nextIndex, options = {}) => {
          const nextTrigger = triggers[nextIndex];
          if (!(nextTrigger instanceof HTMLElement)) return;
          const tabId = nextTrigger.dataset.tabId;
          if (!tabId) return;
          setActiveTab(tabId, options);
          if (options.focus !== false) {
            nextTrigger.focus();
          }
        };

        triggers.forEach((trigger, index) => {
          if (!(trigger instanceof HTMLElement)) return;

          trigger.addEventListener("click", () => {
            const tabId = trigger.dataset.tabId;
            if (!tabId) return;
            setActiveTab(tabId);
          });

          trigger.addEventListener("keydown", (event) => {
            if (event.key === "ArrowRight" || event.key === "ArrowDown") {
              event.preventDefault();
              activateAtIndex((index + 1) % triggers.length);
            }

            if (event.key === "ArrowLeft" || event.key === "ArrowUp") {
              event.preventDefault();
              activateAtIndex((index - 1 + triggers.length) % triggers.length);
            }

            if (event.key === "Home") {
              event.preventDefault();
              activateAtIndex(0);
            }

            if (event.key === "End") {
              event.preventDefault();
              activateAtIndex(triggers.length - 1);
            }
          });
        });

        prevButton?.addEventListener("click", () => {
          const activeIndex = triggers.findIndex(
            (trigger) =>
              trigger instanceof HTMLElement && trigger.getAttribute("aria-selected") === "true",
          );
          const nextIndex = activeIndex <= 0 ? triggers.length - 1 : activeIndex - 1;
          activateAtIndex(nextIndex, { focus: false });
        });

        nextButton?.addEventListener("click", () => {
          const activeIndex = triggers.findIndex(
            (trigger) =>
              trigger instanceof HTMLElement && trigger.getAttribute("aria-selected") === "true",
          );
          const nextIndex = activeIndex >= triggers.length - 1 ? 0 : activeIndex + 1;
          activateAtIndex(nextIndex, { focus: false });
        });

        const firstTab = triggers[0];
        if (firstTab instanceof HTMLElement && firstTab.dataset.tabId) {
          setActiveTab(firstTab.dataset.tabId, { scroll: false });
        }

        tabsRoot.dataset.bound = "true";
      });
    };

    setupScopeTabs();
  })();
</script>

<style>
  .scope-page__banner :global(.page-banner) {
    background: none;
    padding: 10px 0 clamp(1.9rem, 4vw, 2.5rem);
  }

  .scope-page__banner :global(.page-banner__content) {
    align-items: center;
    gap: 0.85rem 1.7rem;
  }

  .scope-page__banner :global(.page-banner h1) {
    font-size: clamp(2.15rem, 4vw, 3.35rem);
  }

  .scope-page__section-heading {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .scope-page__tabs {
    width: 100%;
  }

  .scope-page__tabs-section {
    padding-top: 0.3rem;
  }

  .scope-page__tab-item-copy :global(p),
  .scope-page__tab-item-copy :global(ul),
  .scope-page__tab-item-copy :global(ol),
  .scope-page__focus-copy :global(p),
  .scope-page__focus-copy :global(ul),
  .scope-page__focus-copy :global(ol),
  .scope-page__focus-secondary :global(p),
  .scope-page__focus-secondary :global(ul),
  .scope-page__focus-secondary :global(ol),
  .scope-page__recent-copy :global(p),
  .scope-page__recent-copy :global(ul),
  .scope-page__recent-copy :global(ol) {
    margin: 0;
    line-height: 1.7;
  }

  .scope-page__tabs-carousel {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 2rem;
  }

  .scope-page__tabs-menu {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(15rem, calc((100% - 1.8rem) / 3));
    gap: 0.9rem;
    overflow-x: auto;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
  }

  .scope-page__tabs-menu::-webkit-scrollbar {
    display: none;
  }

  .scope-page__tabs-nav {
    width: 3rem;
    height: 3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(22, 60, 61, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.84);
    color: var(--primary);
    box-shadow: 0 10px 22px rgba(16, 47, 48, 0.08);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease;
  }

  .scope-page__tabs-nav:hover {
    transform: translateY(-1px);
    border-color: rgba(22, 60, 61, 0.24);
    background: rgba(255, 255, 255, 0.96);
  }

  .scope-page__tabs-nav svg {
    width: 1.2rem;
    height: 1.2rem;
  }

  .scope-page__tab {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    width: 100%;
    padding: 1rem 1.05rem;
    border: 1px solid rgba(22, 60, 61, 0.12);
    border-radius: 1.1rem;
    background: rgba(255, 255, 255, 0.78);
    color: var(--foreground);
    text-align: left;
    cursor: pointer;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      background-color 180ms ease,
      color 180ms ease;
    box-shadow: 0 12px 28px rgba(16, 47, 48, 0.06);
    scroll-snap-align: start;
  }

  .scope-page__tab.is-active {
    color: var(--white);
    border-color: rgba(22, 60, 61, 0.88);
    background: linear-gradient(135deg, rgba(22, 60, 61, 0.96), rgba(38, 85, 86, 0.94));
    box-shadow: 0 18px 34px rgba(16, 47, 48, 0.18);
  }

  .scope-page__tab:hover {
    transform: translateY(-2px);
    border-color: rgba(22, 60, 61, 0.22);
    box-shadow: 0 16px 34px rgba(16, 47, 48, 0.1);
  }

  .scope-page__tab:focus-visible {
    outline: 2px solid rgba(22, 60, 61, 0.35);
    outline-offset: 2px;
  }

  .scope-page__tab-icon-shell {
    width: 3rem;
    height: 3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    border-radius: 0.9rem;
    background: rgba(22, 60, 61, 0.08);
  }

  .scope-page__tab.is-active .scope-page__tab-icon-shell {
    background: rgba(248, 244, 234, 0.12);
  }

  .scope-page__tab-icon {
    width: 1.55rem;
    height: 1.55rem;
    object-fit: contain;
  }

  .scope-page__tab-copy {
    display: grid;
    gap: 0.22rem;
    min-width: 0;
  }

  .scope-page__tab-label {
    font-size: 1rem;
    line-height: 1.2;
    font-weight: 600;
  }

  .scope-page__tab-meta {
    color: rgba(83, 91, 83, 0.8);
    font-size: 0.82rem;
    line-height: 1.2;
  }

  .scope-page__tab.is-active .scope-page__tab-meta {
    color: rgba(248, 244, 234, 0.76);
  }

  .scope-page__tab-showcase {
    width: 100%;
  }

  .scope-page__tab-summary {
    display: grid;
    grid-template-columns: minmax(19rem, 0.95fr) minmax(0, 1.15fr);
    gap: 1rem;
    align-items: stretch;
  }

  .scope-page__tab-summary-card,
  .scope-page__tab-points-shell {
    border-radius: 1.35rem;
    border: 1px solid rgba(15, 60, 61, 0.1);
    box-shadow: 0 18px 42px rgba(16, 47, 48, 0.08);
    overflow: hidden;
  }

  .scope-page__tab-summary-card {
    display: grid;
    gap: 1.05rem;
    padding: 1.5rem;
    background:
      radial-gradient(circle at top right, rgba(230, 237, 210, 0.4), transparent 30%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(247, 244, 236, 0.94));
  }

  .scope-page__tab-summary-art {
    position: relative;
    min-height: 12rem;
    border-radius: 1.1rem;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(230, 237, 210, 0.45), transparent 28%),
      linear-gradient(135deg, rgba(22, 60, 61, 0.12), rgba(247, 244, 236, 0.82));
    border: 1px solid rgba(15, 60, 61, 0.08);
  }

  .scope-page__tab-summary-art img {
    width: 100%;
    height: 100%;
    min-height: 12rem;
    object-fit: contain;
    padding: 1.25rem;
  }

  .scope-page__tab-summary-top {
    display: grid;
    gap: 1rem;
  }

  .scope-page__tab-summary-eyebrow {
    width: fit-content;
    padding: 0.32rem 0.62rem;
    border-radius: 999px;
    background: rgba(22, 60, 61, 0.08);
    color: var(--primary);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .scope-page__tab-summary-head {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .scope-page__tab-summary-icon-shell {
    width: 4rem;
    height: 4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    border-radius: 1.15rem;
    background: rgba(22, 60, 61, 0.08);
  }

  .scope-page__tab-summary-icon {
    width: 2rem;
    height: 2rem;
    object-fit: contain;
  }

  .scope-page__tab-summary-title-wrap {
    display: grid;
    gap: 0.35rem;
    min-width: 0;
  }

  .scope-page__tab-summary-kicker {
    color: var(--primary);
    font-size: 0.86rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .scope-page__tab-item-title {
    color: var(--primary);
    font-size: clamp(1.6rem, 2.7vw, 2.25rem);
    line-height: 1.08;
  }

  .scope-page__tab-item-copy {
    color: var(--foreground);
    line-height: 1.56;
  }

  .scope-page__tab-lead {
    color: var(--foreground);
    font-size: 1rem;
    line-height: 1.7;
  }

  .scope-page__tab-lead :global(p),
  .scope-page__tab-lead :global(ul),
  .scope-page__tab-lead :global(ol) {
    margin: 0;
    line-height: 1.7;
  }

  .scope-page__tab-summary-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    margin-top: auto;
  }

  .scope-page__tab-stat {
    display: grid;
    gap: 0.16rem;
  }

  .scope-page__tab-stat strong {
    color: var(--primary);
    font-size: 1.75rem;
    line-height: 1;
    font-weight: 500;
    letter-spacing: -0.05em;
  }

  .scope-page__tab-stat span {
    color: rgba(83, 91, 83, 0.86);
    font-size: 0.86rem;
    line-height: 1.2;
  }

  .scope-page__tab-cta {
    width: fit-content;
  }

  .scope-page__tab-points-shell {
    padding: 1.35rem;
    background: rgba(255, 255, 255, 0.9);
  }

  .scope-page__tab-points-head {
    margin-bottom: 1rem;
  }

  .scope-page__tab-points-head p {
    color: var(--primary);
    font-size: 0.86rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .scope-page__tab-points-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .scope-page__tab-point {
    display: grid;
    gap: 0.6rem;
    min-height: 100%;
    padding: 1rem;
    border-radius: 1rem;
    background: linear-gradient(180deg, rgba(226, 237, 223, 0.48), rgba(248, 244, 234, 0.82));
    border: 1px solid rgba(15, 60, 61, 0.08);
  }

  .scope-page__tab-point-index {
    color: rgba(22, 60, 61, 0.54);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .scope-page__tab-point h4 {
    font-size: 1.15rem;
    line-height: 1.18;
  }

  .scope-page__tab-point-copy,
  .scope-page__tab-point-copy :global(p),
  .scope-page__tab-point-copy :global(ul),
  .scope-page__tab-point-copy :global(ol) {
    color: var(--foreground);
    margin: 0;
    line-height: 1.6;
  }

  .scope-page__focus-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 5vw, 3.75rem);
    align-items: center;
  }

  .scope-page__focus-image {
