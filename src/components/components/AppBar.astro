---
import { getLocalePrefix, localizePath } from "@/features/i18n/locale";
import { getDictionary } from "@/features/i18n/translate";
import { siteConfig, type SiteLocale } from "@/lib/config/site";

type Props = {
  locale: SiteLocale;
  pathname: string;
  initialTone?: "light" | "dark";
};

const { locale, pathname, initialTone = "light" } = Astro.props;
const dictionary = getDictionary(locale);
const latnDictionary = getDictionary("sr-latn");
const cyrlDictionary = getDictionary("sr-cyrl");
const currentWithoutPrefix =
  locale === "sr-cyrl" ? pathname.replace(/^\/cir/, "") || "/" : pathname || "/";
const latnHref = currentWithoutPrefix;
const cyrlHref = `${getLocalePrefix("sr-cyrl")}${currentWithoutPrefix}`.replace("//", "/");
const isActivePath = (href: string) =>
  href === "/" ? pathname === href : pathname.startsWith(href);
const primaryBiographyHref = localizePath(locale, "/biografija/nemanja-zajkeskovic/");

const aboutLinks = [
  { label: dictionary.nav.aboutLinks.about, href: localizePath(locale, "/o-nama/") },
  { label: dictionary.nav.aboutLinks.biography, href: primaryBiographyHref },
];

const therapyLinks = [
  { label: dictionary.nav.therapyLinks.approach, href: localizePath(locale, "/psihoterapija/") },
  { label: dictionary.nav.therapyLinks.scope, href: localizePath(locale, "/oblast-rada/") },
  { label: dictionary.nav.therapyLinks.pricing, href: localizePath(locale, "/cena/") },
  { label: dictionary.nav.therapyLinks.appointment, href: localizePath(locale, "/zakazivanje/") },
];
---

<header class="appbar appbar--solid" data-appbar-root data-initial-tone={initialTone}>
  <div class="container">
    <div class="appbar__panel">
      <a class="appbar__brand" href={localizePath(locale, "/")} aria-label={siteConfig.name}>
        <img
          class="appbar__brand-logo appbar__brand-logo--light"
          src="/legacy/images/Logo-White.svg"
          alt={siteConfig.name}
        />
        <img
          class="appbar__brand-logo appbar__brand-logo--dark"
          src="/legacy/images/Logo-Dark.svg"
          alt={siteConfig.name}
        />
      </a>

      <div class="appbar__desktop">
        <nav class="appbar__nav" aria-label={dictionary.a11y.appbarPrimaryNav}>
          <a
            class:list={["appbar__link", isActivePath(localizePath(locale, "/")) && "is-active"]}
            href={localizePath(locale, "/")}
          >
            {dictionary.nav.home}
          </a>

          <details class="appbar__dropdown" data-appbar-dropdown>
            <summary class="appbar__link">
              <span>{dictionary.nav.about}</span>
              <span class="appbar__chevron" aria-hidden="true"></span>
            </summary>
            <div class="appbar__dropdown-menu">
              {
                aboutLinks.map((item) => (
                  <a
                    class:list={["appbar__dropdown-link", isActivePath(item.href) && "is-active"]}
                    href={item.href}
                    aria-label={item.label}
                  >
                    {item.label}
                  </a>
                ))
              }
            </div>
          </details>

          <details class="appbar__dropdown" data-appbar-dropdown>
            <summary class="appbar__link">
              <span>{dictionary.nav.psychotherapy}</span>
              <span class="appbar__chevron" aria-hidden="true"></span>
            </summary>
            <div class="appbar__dropdown-menu">
              {
                therapyLinks.map((item) => (
                  <a
                    class:list={["appbar__dropdown-link", isActivePath(item.href) && "is-active"]}
                    href={item.href}
                    aria-label={item.label}
                  >
                    {item.label}
                  </a>
                ))
              }
            </div>
          </details>

          <a
            class:list={[
              "appbar__link",
              isActivePath(localizePath(locale, "/blog/")) && "is-active",
            ]}
            href={localizePath(locale, "/blog/")}
          >
            {dictionary.nav.blog}
          </a>
          <a
            class:list={[
              "appbar__link",
              isActivePath(localizePath(locale, "/pitanja/")) && "is-active",
            ]}
            href={localizePath(locale, "/pitanja/")}
          >
            {dictionary.nav.faq}
          </a>
        </nav>

        <div class="appbar__actions">
          <div
            class="appbar__locale-toggle"
            aria-label={dictionary.a11y.localeSwitch}
            data-locale-toggle
            data-active-locale={locale}
          >
            {
              locale === "sr-latn" ? (
                <span class="appbar__locale-chip" aria-current="page" data-locale-chip-id="sr-latn">
                  {latnDictionary.localeShortLabel}
                </span>
              ) : (
                <a
                  class="appbar__locale-chip"
                  href={latnHref}
                  data-astro-prefetch
                  data-locale-chip-target
                  data-next-locale="sr-latn"
                  data-locale-chip-id="sr-latn"
                >
                  {latnDictionary.localeShortLabel}
                </a>
              )
            }
            {
              locale === "sr-cyrl" ? (
                <span class="appbar__locale-chip" aria-current="page" data-locale-chip-id="sr-cyrl">
                  {cyrlDictionary.localeShortLabel}
                </span>
              ) : (
                <a
                  class="appbar__locale-chip"
                  href={cyrlHref}
                  data-astro-prefetch
                  data-locale-chip-target
                  data-next-locale="sr-cyrl"
                  data-locale-chip-id="sr-cyrl"
                >
                  {cyrlDictionary.localeShortLabel}
                </a>
              )
            }
          </div>
          <a class="appbar__cta" href={localizePath(locale, "/kontakt/")}>
            {dictionary.nav.contact}
          </a>
        </div>
      </div>

      <details class="appbar__mobile" data-appbar-mobile>
        <summary class="appbar__toggle" aria-label={dictionary.a11y.toggleNavigation}>
          <img class="appbar__toggle-icon" src="/legacy/images/menu-btn.svg" alt="" />
        </summary>

        <button class="appbar__backdrop" type="button" aria-label={dictionary.a11y.toggleNavigation}
        ></button>

        <div class="appbar__drawer">
          <div class="appbar__drawer-header">
            <img
              class="appbar__drawer-logo"
              src="/legacy/images/Logo-Dark.svg"
              alt={siteConfig.name}
            />
            <button
              class="appbar__drawer-close"
              type="button"
              aria-label={dictionary.a11y.toggleNavigation}
            >
              <span></span>
              <span></span>
            </button>
          </div>

          <div class="appbar__drawer-body">
            <a
              class:list={[
                "appbar__drawer-link",
                isActivePath(localizePath(locale, "/")) && "is-active",
              ]}
              href={localizePath(locale, "/")}
            >
              {dictionary.nav.home}
            </a>

            <details class="appbar__drawer-group">
              <summary>
                <span>{dictionary.nav.about}</span>
                <span class="appbar__drawer-chevron" aria-hidden="true"></span>
              </summary>
              <div class="appbar__drawer-group-links">
                {
                  aboutLinks.map((item) => (
                    <a
                      class:list={[
                        "appbar__drawer-sublink",
                        isActivePath(item.href) && "is-active",
                      ]}
                      href={item.href}
                    >
                      {item.label}
                    </a>
                  ))
                }
              </div>
            </details>

            <details class="appbar__drawer-group">
              <summary>
                <span>{dictionary.nav.psychotherapy}</span>
                <span class="appbar__drawer-chevron" aria-hidden="true"></span>
              </summary>
              <div class="appbar__drawer-group-links">
                {
                  therapyLinks.map((item) => (
                    <a
                      class:list={[
                        "appbar__drawer-sublink",
                        isActivePath(item.href) && "is-active",
                      ]}
                      href={item.href}
                    >
                      {item.label}
                    </a>
                  ))
                }
              </div>
            </details>

            <a
              class:list={[
                "appbar__drawer-link",
                isActivePath(localizePath(locale, "/blog/")) && "is-active",
              ]}
              href={localizePath(locale, "/blog/")}
            >
              {dictionary.nav.blog}
            </a>
            <a
              class:list={[
                "appbar__drawer-link",
                isActivePath(localizePath(locale, "/pitanja/")) && "is-active",
              ]}
              href={localizePath(locale, "/pitanja/")}
            >
              {dictionary.nav.faq}
            </a>
          </div>

          <div class="appbar__drawer-actions">
            <div
              class="appbar__locale-toggle appbar__locale-toggle--drawer"
              aria-label={dictionary.a11y.localeSwitch}
              data-locale-toggle
              data-active-locale={locale}
            >
              {
                locale === "sr-latn" ? (
                  <span
                    class="appbar__locale-chip"
                    aria-current="page"
                    data-locale-chip-id="sr-latn"
                  >
                    {latnDictionary.localeShortLabel}
                  </span>
                ) : (
                  <a
                    class="appbar__locale-chip"
                    href={latnHref}
                    data-astro-prefetch
                    data-locale-chip-target
                    data-next-locale="sr-latn"
                    data-locale-chip-id="sr-latn"
                  >
                    {latnDictionary.localeShortLabel}
                  </a>
                )
              }
              {
                locale === "sr-cyrl" ? (
                  <span
                    class="appbar__locale-chip"
                    aria-current="page"
                    data-locale-chip-id="sr-cyrl"
                  >
                    {cyrlDictionary.localeShortLabel}
                  </span>
                ) : (
                  <a
                    class="appbar__locale-chip"
                    href={cyrlHref}
                    data-astro-prefetch
                    data-locale-chip-target
                    data-next-locale="sr-cyrl"
                    data-locale-chip-id="sr-cyrl"
                  >
                    {cyrlDictionary.localeShortLabel}
                  </a>
                )
              }
            </div>
            <a class="appbar__cta" href={localizePath(locale, "/zakazivanje/")}>
              {dictionary.nav.appointment}
            </a>
          </div>
        </div>
      </details>
    </div>
  </div>
</header>

<script type="module" src="/scripts/appbar.js"></script>
