---
import BaseLayout from "@/components/components/BaseLayout.astro";
import { getDictionary } from "@/features/i18n/translate";
import "@/styles/admin.css";

type Props = {
  title: string;
  description?: string;
};

const dictionary = getDictionary("sr-latn");
const { title, description = dictionary.meta.admin.layoutDescription } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  locale="sr-latn"
  canonicalPath={Astro.url.pathname}
  appBarVariant="admin"
  bodyClass="admin-shell"
>
  <div class="admin-shell__backdrop" aria-hidden="true">
    <div class="admin-shell__orb admin-shell__orb--one"></div>
    <div class="admin-shell__orb admin-shell__orb--two"></div>
    <div class="admin-shell__mesh"></div>
  </div>

  <section class="section">
    <div class="container">
      <div class="admin-shell__frame">
        <div class="admin-grid">
          <slot />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
