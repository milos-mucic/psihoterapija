---
import { AdminMediaField } from "@/components/components/AdminMediaField";
import { AdminRichTextField } from "@/components/components/AdminRichTextField";
import type { HomePageManagedContent } from "@/features/page-content/types/page-content.types";
import type { SiteLocale } from "@/lib/config/site";

type Props = {
  action: string;
  content: HomePageManagedContent;
  locale: SiteLocale;
  previewBaseHref: string;
  localeLabel: string;
};

const { action, content, locale, previewBaseHref, localeLabel } = Astro.props;
const localeOptions: Array<{ value: SiteLocale; label: string }> = [
  { value: "sr-latn", label: "Latinica" },
  { value: "sr-cyrl", label: "Ćirilica" },
];
const videoAccept = "video/*,.mp4,.webm,.mov,.ogg,.ogv";
const richTextLabels = {
  bold: "Bold",
  italic: "Italic",
  underline: "Underline",
  heading2: "Heading 2",
  heading3: "Heading 3",
  bulletList: "Lista",
  orderedList: "Numerisana lista",
  quote: "Citat",
  link: "Link",
  image: "Slika",
  clear: "Ukloni format",
  uploadFailed: "Upload slike nije uspeo.",
};

const heroTitleRichTextLabels = {
  ...richTextLabels,
  placeholder: "Naslov hero sekcije",
};
---

<form
  class="admin-form"
  method="post"
  action={action}
  data-admin-section-preview-root
  data-preview-base-href={previewBaseHref}
  data-preview-locale-label={localeLabel}
>
  <input type="hidden" name="locale" value={locale} />

  <div class="card" style="padding: 1.5rem;">
    <div class="admin-form__grid">
      <label class="admin-form__field">
        <span>Jezik sadržaja</span>
        <select class="input-control" name="localeDisplay" disabled>
          {
            localeOptions.map((option) => (
              <option value={option.value} selected={option.value === locale}>
                {option.label}
              </option>
            ))
          }
        </select>
      </label>
    </div>
  </div>

  <div
    class="card"
    style="padding: 1.5rem;"
    data-section-preview
    data-section-preview-fragment="home-hero"
  >
    <div class="page-grid">
      <div>
        <h2 style="margin: 0;">Hero sekcija</h2>
        <p class="section-copy">Naslov i opis sada koriste isti Lexical rich text editor.</p>
      </div>

      <div class="admin-form__grid">
        <div class="admin-form__field admin-form__field--full">
          <span>Naslov hero sekcije</span>
          <AdminRichTextField
            client:load
            name="heroTitleHtml"
            initialValue={content.hero.titleHtml}
            mode="inline"
            uploadUrl="/api/admin/media/upload"
            uploadFolder="pages/home"
            labels={heroTitleRichTextLabels}
          />
        </div>

        <div class="admin-form__field admin-form__field--full">
          <span>Opis hero sekcije</span>
          <AdminRichTextField
            client:load
            name="heroDescription"
            initialValue={content.hero.description}
            uploadUrl="/api/admin/media/upload"
            uploadFolder="pages/home"
            labels={richTextLabels}
          />
        </div>

        <label class="admin-form__field">
          <span>Labela primarnog dugmeta</span>
          <input
            class="input-control"
            name="heroPrimaryActionLabel"
            value={content.hero.primaryActionLabel}
          />
        </label>

        <label class="admin-form__field">
          <span>Labela sekundarnog linka</span>
          <input
            class="input-control"
            name="heroSecondaryActionLabel"
            value={content.hero.secondaryActionLabel}
          />
        </label>
      </div>
    </div>
  </div>

  <div
    class="card"
    style="padding: 1.5rem;"
    data-section-preview
    data-section-preview-fragment="home-prompt"
  >
    <div class="page-grid">
      <div>
        <h2 style="margin: 0;">Kontakt prompt</h2>
        <p class="section-copy">Sekcija odmah ispod hero dela.</p>
      </div>

      <div class="admin-form__grid">
        <label class="admin-form__field">
          <span>Naslov</span>
          <input class="input-control" name="promptTitle" value={content.prompt.title} />
        </label>

        <label class="admin-form__field">
          <span>Labela dugmeta</span>
          <input class="input-control" name="promptLabel" value={content.prompt.label} />
        </label>

        <div class="admin-form__field admin-form__field--full">
          <span>Tekst</span>
          <AdminRichTextField
            client:load
            name="promptCopy"
            initialValue={content.prompt.copy}
            uploadUrl="/api/admin/media/upload"
            uploadFolder="pages/home"
            labels={richTextLabels}
          />
        </div>
      </div>
    </div>
  </div>

  <div
    class="card"
    style="padding: 1.5rem;"
    data-section-preview
    data-section-preview-fragment="home-about"
  >
    <div class="page-grid">
      <div>
        <h2 style="margin: 0;">O terapeutu</h2>
        <p class="section-copy">Opis je objedinjeni rich text dokument sa paragrafima i listama.</p>
      </div>

      <div class="admin-form__grid">
        <label class="admin-form__field admin-form__field--full">
          <span>Naslov</span>
          <input class="input-control" name="aboutTitle" value={content.about.title} />
        </label>

        <AdminMediaField
          client:load
          name="aboutImage"
          label="Slika"
          initialValue={content.about.image}
          uploadUrl="/api/admin/media/upload"
          uploadFolder="pages/home"
          uploadLabel="Dodaj sliku"
        />

        <div class="admin-form__field admin-form__field--full">
          <span>Opis</span>
          <AdminRichTextField
            client:load
            name="aboutBody"
            initialValue={content.about.body}
            uploadUrl="/api/admin/media/upload"
            uploadFolder="pages/home"
            labels={richTextLabels}
          />
        </div>

        <label class="admin-form__field">
          <span>Labela dugmeta</span>
          <input class="input-control" name="aboutLabel" value={content.about.label} />
        </label>
      </div>
    </div>
  </div>

  <div
    class="card"
    style="padding: 1.5rem;"
    data-section-preview
    data-section-preview-fragment="home-services"
  >
    <div class="page-grid">
      <div>
        <h2 style="margin: 0;">Usluge</h2>
        <p class="section-copy">Opis sekcije i opisi kartica koriste rich text editor.</p>
      </div>

      <div class="admin-form__grid">
        <label class="admin-form__field">
          <span>Naslov sekcije</span>
          <input class="input-control" name="servicesTitle" value={content.services.title} />
        </label>

        <div class="admin-form__field admin-form__field--full">
          <span>Opis sekcije</span>
          <AdminRichTextField
            client:load
            name="servicesCopy"
            initialValue={content.services.copy}
            uploadUrl="/api/admin/media/upload"
            uploadFolder="pages/home"
            labels={richTextLabels}
          />
        </div>

        {
          content.services.items.map((item, index) => (
            <div class="admin-section-group admin-form__field--full">
              <h3 style="margin: 0;">Kartica {index + 1}</h3>
              <div class="admin-form__grid">
                <label class="admin-form__field">
                  <span>Naslov</span>
                  <input
                    class="input-control"
                    name={`service${index + 1}Title`}
                    value={item.title}
                  />
                </label>

                <AdminMediaField
                  client:load
                  name={`service${index + 1}Image`}
                  label="Ikonica / slika"
                  initialValue={item.image}
                  uploadUrl="/api/admin/media/upload"
                  uploadFolder="pages/home"
                  uploadLabel="Dodaj sliku"
                />

                <div class="admin-form__field admin-form__field--full">
                  <span>Opis</span>
                  <AdminRichTextField
                    client:load
                    name={`service${index + 1}Copy`}
                    initialValue={item.copy}
                    uploadUrl="/api/admin/media/upload"
                    uploadFolder="pages/home"
                    labels={richTextLabels}
                  />
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div
    class="card"
    style="padding: 1.5rem;"
    data-section-preview
    data-section-preview-fragment="home-themes"
  >
    <div class="page-grid">
      <div>
        <h2 style="margin: 0;">Teme rada</h2>
        <p class="section-copy">Tri kartice sa slikom i rich text opisom.</p>
      </div>

      <div class="admin-form__grid">
        <label class="admin-form__field">
          <span>Naslov sekcije</span>
          <input class="input-control" name="themesTitle" value={content.themes.title} />
        </label>

        {
          content.themes.items.map((item, index) => (
            <div class="admin-section-group admin-form__field--full">
              <h3 style="margin: 0;">Tema {index + 1}</h3>
              <div class="admin-form__grid">
                <label class="admin-form__field">
                  <span>Naslov</span>
                  <input class="input-control" name={`theme${index + 1}Title`} value={item.title} />
                </label>

                <label class="admin-form__field">
                  <span>Labela linka</span>
                  <input class="input-control" name={`theme${index + 1}Label`} value={item.label} />
                </label>

                <AdminMediaField
                  client:load
                  name={`theme${index + 1}Image`}
                  label="Slika"
                  initialValue={item.image}
                  uploadUrl="/api/admin/media/upload"
                  uploadFolder="pages/home"
                  uploadLabel="Dodaj sliku"
                />

                <div class="admin-form__field admin-form__field--full">
                  <span>Opis</span>
                  <AdminRichTextField
                    client:load
                    name={`theme${index + 1}Copy`}
                    initialValue={item.copy}
                    uploadUrl="/api/admin/media/upload"
                    uploadFolder="pages/home"
                    labels={richTextLabels}
                  />
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div
    class="card"
    style="padding: 1.5rem;"
    data-section-preview
    data-section-preview-fragment="home-reasons"
  >
    <div class="page-grid">
      <div>
        <h2 style="margin: 0;">Zašto Ikar</h2>
        <p class="section-copy">
          Opis sekcije i opisi razloga su rich text. Video ostaje URL ili upload.
        </p>
      </div>

      <div class="admin-form__grid">
        <label class="admin-form__field">
          <span>Naslov sekcije</span>
          <input class="input-control" name="reasonsTitle" value={content.reasons.title} />
        </label>

        <div class="admin-form__field admin-form__field--full">
          <span>Opis sekcije</span>
          <AdminRichTextField
            client:load
            name="reasonsCopy"
            initialValue={content.reasons.copy}
            uploadUrl="/api/admin/media/upload"
            uploadFolder="pages/home"
            labels={richTextLabels}
          />
        </div>

        {
          content.reasons.items.map((item, index) => (
            <div class="admin-section-group admin-form__field--full">
              <h3 style="margin: 0;">Razlog {index + 1}</h3>
              <div class="admin-form__grid">
                <label class="admin-form__field">
                  <span>Naslov</span>
                  <input
                    class="input-control"
                    name={`reason${index + 1}Title`}
                    value={item.title}
                  />
                </label>

                <label class="admin-form__field">
                  <span>Labela linka</span>
                  <input
                    class="input-control"
                    name={`reason${index + 1}Label`}
                    value={item.label}
                  />
                </label>

                <div class="admin-form__field admin-form__field--full">
                  <span>Opis</span>
                  <AdminRichTextField
                    client:load
                    name={`reason${index + 1}Copy`}
                    initialValue={item.copy}
                    uploadUrl="/api/admin/media/upload"
                    uploadFolder="pages/home"
                    labels={richTextLabels}
                  />
                </div>
              </div>
            </div>
          ))
        }

        <AdminMediaField
          client:load
          name="reasonsVideoUrl"
          label="Video URL ili otpremljen video"
          initialValue={content.reasons.videoUrl}
          uploadUrl="/api/admin/media/upload"
          uploadFolder="pages/home"
          accept={videoAccept}
          uploadLabel="Otpremi video"
          helpText="Možete ostaviti YouTube/Vimeo URL ili otpremiti direktan video fajl."
        />

        <AdminMediaField
          client:load
          name="reasonsVideoImage"
          label="Poster / preview slika videa"
          initialValue={content.reasons.videoImage}
          uploadUrl="/api/admin/media/upload"
          uploadFolder="pages/home"
          uploadLabel="Dodaj sliku"
        />

        <label class="admin-form__field">
          <span>Labela videa</span>
          <input
            class="input-control"
            name="reasonsVideoLabel"
            value={content.reasons.videoLabel}
          />
        </label>
      </div>
    </div>
  </div>

  <div
    class="card"
    style="padding: 1.5rem;"
    data-section-preview
    data-section-preview-fragment="home-booking"
  >
    <div class="page-grid">
      <div>
        <h2 style="margin: 0;">Zakazivanje</h2>
        <p class="section-copy">Opis sekcije je jedan rich text dokument.</p>
      </div>

      <div class="admin-form__grid">
        <label class="admin-form__field">
          <span>Naslov sekcije</span>
          <input class="input-control" name="bookingTitle" value={content.booking.title} />
        </label>

        <div class="admin-form__field admin-form__field--full">
          <span>Opis sekcije</span>
          <AdminRichTextField
            client:load
            name="bookingCopy"
            initialValue={content.booking.copy}
            uploadUrl="/api/admin/media/upload"
            uploadFolder="pages/home"
            labels={richTextLabels}
          />
        </div>

        <label class="admin-form__field">
          <span>Labela iznad izbora formata</span>
          <input
            class="input-control"
            name="bookingFormatLabel"
            value={content.booking.formatLabel}
          />
        </label>

        <label class="admin-form__field">
          <span>Format 1</span>
          <input
            class="input-control"
            name="bookingFormat1"
            value={content.booking.formats[0] ?? ""}
          />
        </label>

        <label class="admin-form__field">
          <span>Format 2</span>
          <input
            class="input-control"
            name="bookingFormat2"
            value={content.booking.formats[1] ?? ""}
          />
        </label>

        <label class="admin-form__field">
          <span>Format 3</span>
          <input
            class="input-control"
            name="bookingFormat3"
            value={content.booking.formats[2] ?? ""}
          />
        </label>
      </div>
    </div>
  </div>

  <div
    class="card"
    style="padding: 1.5rem;"
    data-section-preview
    data-section-preview-fragment="home-blog"
  >
    <div class="page-grid">
      <div>
        <h2 style="margin: 0;">Blog sekcija</h2>
        <p class="section-copy">
          Opis sekcije je rich text, a fallback poruka ostaje običan tekst.
        </p>
      </div>

      <div class="admin-form__grid">
        <label class="admin-form__field">
          <span>Naslov sekcije</span>
          <input class="input-control" name="recentTitle" value={content.recent.title} />
        </label>

        <label class="admin-form__field">
          <span>Labela dugmeta</span>
          <input class="input-control" name="recentLabel" value={content.recent.label} />
        </label>

        <div class="admin-form__field admin-form__field--full">
          <span>Opis sekcije</span>
          <AdminRichTextField
            client:load
            name="recentCopy"
            initialValue={content.recent.copy}
            uploadUrl="/api/admin/media/upload"
            uploadFolder="pages/home"
            labels={richTextLabels}
          />
        </div>

        <label class="admin-form__field admin-form__field--full">
          <span>Poruka kada nema blog postova</span>
          <textarea class="input-control input-control--textarea" name="recentEmpty" rows={2}
            >{content.recent.empty}</textarea
          >
        </label>
      </div>
    </div>
  </div>

  <div class="admin-form__actions admin-form__actions--floating">
    <p class="admin-form__save-status" data-admin-form-submit-status aria-live="polite"></p>
    <button class="button-primary admin-form__fab" type="submit" data-admin-form-submit>
      Sačuvaj početnu stranu
    </button>
  </div>
</form>

<script is:inline>
  (() => {
    const setupFloatingSubmit = () => {
      document.querySelectorAll("[data-admin-section-preview-root]").forEach((form) => {
        if (!(form instanceof HTMLFormElement) || form.dataset.floatingSubmitBound === "true") {
          return;
        }

        const submitButtons = Array.from(form.querySelectorAll("[data-admin-form-submit]")).filter(
          (button) => button instanceof HTMLButtonElement,
        );
        const statusNodes = Array.from(
          form.querySelectorAll("[data-admin-form-submit-status]"),
        ).filter((node) => node instanceof HTMLElement);
        const pendingSources = new Map();
        let autoSaveRequested = false;
        let isSubmitting = false;

        const syncSubmitState = () => {
          const hasPending = pendingSources.size > 0;
          const message = isSubmitting
            ? "Čuvanje u toku..."
            : autoSaveRequested && hasPending
              ? "Završavam upload pa čuvam izmenu slike."
              : autoSaveRequested
                ? "Čuvam izmenu slike..."
                : hasPending
                  ? "Sačekajte da se obrada slike ili videa završi."
                  : "Sve media izmene su spremne za čuvanje.";

          form.dataset.pendingUploads = hasPending ? "true" : "false";

          submitButtons.forEach((button) => {
            button.disabled = hasPending;
            button.setAttribute("aria-disabled", hasPending ? "true" : "false");
          });

          statusNodes.forEach((node) => {
            node.textContent = message;
            node.dataset.tone = hasPending ? "muted" : "ready";
          });
        };

        const tryAutoSave = () => {
          if (!autoSaveRequested || isSubmitting || form.dataset.pendingUploads === "true") {
            return;
          }

          if (!form.checkValidity()) {
            autoSaveRequested = false;
            syncSubmitState();
            return;
          }

          requestAnimationFrame(() => form.requestSubmit());
        };

        form.addEventListener("admin:pending-media", (event) => {
          if (!(event instanceof CustomEvent)) {
            return;
          }

          const sourceId =
            typeof event.detail?.sourceId === "string" ? event.detail.sourceId : undefined;

          if (!sourceId) {
            return;
          }

          if (event.detail?.active) {
            pendingSources.set(sourceId, true);
          } else {
            pendingSources.delete(sourceId);
          }

          syncSubmitState();
          tryAutoSave();
        });

        form.addEventListener("admin:auto-save-media", () => {
          autoSaveRequested = true;
          syncSubmitState();
          tryAutoSave();
        });

        form.addEventListener("submit", (event) => {
          if (form.dataset.pendingUploads === "true") {
            event.preventDefault();
            syncSubmitState();
            return;
          }

          if (isSubmitting) {
            event.preventDefault();
            return;
          }

          isSubmitting = true;
          syncSubmitState();
        });

        syncSubmitState();
        form.dataset.floatingSubmitBound = "true";
      });
    };

    const setupSectionPreviews = () => {
      document.querySelectorAll("[data-admin-section-preview-root]").forEach((form) => {
        if (!(form instanceof HTMLFormElement) || form.dataset.sectionPreviewBound === "true") {
          return;
        }

        const baseHref = form.dataset.previewBaseHref ?? "";
        const editorRoot = form.closest("[data-admin-page-editor]");
        const nav = editorRoot?.querySelector("[data-admin-section-nav]");
        const previewFrame = editorRoot?.querySelector("[data-admin-preview-iframe]");
        const previewLink = editorRoot?.querySelector("[data-admin-preview-open]");
        const sections = Array.from(form.children).filter(
          (child) => child instanceof HTMLElement && child.matches("[data-section-preview]"),
        );

        const activateSection = (nextIndex) => {
          sections.forEach((section, index) => {
            if (!(section instanceof HTMLElement)) {
              return;
            }

            const isActive = index === nextIndex;
            section.classList.toggle("is-active", isActive);
            section.classList.toggle("is-collapsed", !isActive);

            const navButton = nav?.querySelector(`[data-admin-section-nav-index="${index}"]`);
            navButton?.classList.toggle("is-active", isActive);
            navButton?.setAttribute("aria-current", isActive ? "true" : "false");
          });

          const activeSection = sections[nextIndex];
          if (!(activeSection instanceof HTMLElement)) {
            return;
          }

          const fragment = activeSection.dataset.sectionPreviewFragment ?? "";
          const href = fragment ? `${baseHref}#${fragment}` : baseHref;

          if (previewFrame instanceof HTMLIFrameElement && previewFrame.src !== href) {
            previewFrame.src = href;
          }

          if (previewLink instanceof HTMLAnchorElement) {
            previewLink.href = href;
          }
        };

        sections.forEach((child, index) => {
          if (!(child instanceof HTMLElement) || !child.matches("[data-section-preview]")) {
            return;
          }

          const fragment = child.dataset.sectionPreviewFragment ?? "";
          const href = fragment ? `${baseHref}#${fragment}` : baseHref;
          const title =
            child.dataset.sectionPreviewTitle ??
            child.querySelector("h2")?.textContent?.trim() ??
            "Preview sekcije";
          const copy =
            child.dataset.sectionPreviewCopy ??
            child.querySelector(".section-copy")?.textContent?.trim() ??
            "";

          child.classList.add("admin-section-editor");
          child.classList.toggle("is-active", index === 0);
          child.classList.toggle("is-collapsed", index !== 0);

          const existingNodes = Array.from(child.childNodes);
          const body = document.createElement("div");
          body.className = "admin-section-editor__body";
          existingNodes.forEach((node) => body.append(node));

          const header = document.createElement("div");
          header.className = "admin-section-editor__header";

          const badge = document.createElement("span");
          badge.className = "admin-section-editor__badge";
          badge.textContent = String(index + 1).padStart(2, "0");

          const meta = document.createElement("div");
          meta.className = "admin-section-editor__meta";

          const heading = document.createElement("h2");
          heading.textContent = title;
          meta.append(heading);

          if (copy) {
            const summary = document.createElement("p");
            summary.className = "admin-section-editor__copy";
            summary.textContent = copy;
            meta.append(summary);
          }

          const actions = document.createElement("div");
          actions.className = "admin-section-editor__actions";

          const toggle = document.createElement("button");
          toggle.type = "button";
          toggle.className = "button-primary admin-section-editor__toggle";
          toggle.textContent = "Uredi sekciju";
          toggle.addEventListener("click", () => activateSection(index));

          const link = document.createElement("a");
          link.className = "button-secondary";
          link.href = href;
          link.target = "_blank";
          link.rel = "noreferrer";
          link.textContent = "Otvori javnu sekciju";

          actions.append(toggle, link);
          header.append(badge, meta, actions);

          child.replaceChildren(header, body);

          if (nav instanceof HTMLElement) {
            const navButton = document.createElement("button");
            navButton.type = "button";
            navButton.className = `admin-section-nav__button${index === 0 ? " is-active" : ""}`;
            navButton.dataset.adminSectionNavIndex = String(index);

            const navIndex = document.createElement("span");
            navIndex.className = "admin-section-nav__index";
            navIndex.textContent = String(index + 1).padStart(2, "0");

            const navTitle = document.createElement("span");
            navTitle.className = "admin-section-nav__title";
            navTitle.textContent = title;

            navButton.append(navIndex, navTitle);

            if (copy) {
              const navCopy = document.createElement("span");
              navCopy.className = "admin-section-nav__copy";
              navCopy.textContent = copy;
              navButton.append(navCopy);
            }

            navButton.addEventListener("click", () => activateSection(index));
            nav.append(navButton);
          }

          child.addEventListener(
            "invalid",
            (event) => {
              if (event.target instanceof HTMLElement) {
                activateSection(index);
              }
            },
            true,
          );
        });

        activateSection(0);
        form.dataset.sectionPreviewBound = "true";
      });
    };

    setupFloatingSubmit();
    setupSectionPreviews();
    document.addEventListener("astro:page-load", setupFloatingSubmit);
