---
import type { ScopePageManagedContent } from "@/features/page-content/types/page-content.types";

type Props = {
  fragment: string;
  title: string;
  copy: string;
  tabs: ScopePageManagedContent["tabs"];
  richTextLabels: Record<string, string>;
};

const { fragment, title, copy, tabs, richTextLabels } = Astro.props;
---

<div
  class="card"
  style="padding: 1.5rem;"
  data-section-preview
  data-section-preview-fragment={fragment}
>
  <div class="page-grid">
    <div>
      <h2 style="margin: 0;">{title}</h2>
      <p class="section-copy">{copy}</p>
    </div>

    <div class="admin-form__grid">
      <div
        class="admin-form__field admin-form__field--full"
        data-scope-tab-list
        data-scope-tab-rich-text-labels={JSON.stringify(richTextLabels)}
      >
        {
          tabs.map((tab, index) => (
            <div class="admin-section-group admin-form__field--full" data-scope-tab-item>
              <div style="display: flex; justify-content: space-between; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
                <h3 style="margin: 0;" data-scope-tab-title>
                  Tema {index + 1}
                </h3>
                <button class="button-secondary" type="button" data-scope-tab-remove>
                  Obriši temu
                </button>
              </div>

              <div class="admin-form__grid">
                <label class="admin-form__field">
                  <span>Slug</span>
                  <input class="input-control" data-scope-tab-field="id" value={tab.id} />
                </label>

                <label class="admin-form__field">
                  <span>Labela</span>
                  <input class="input-control" data-scope-tab-field="label" value={tab.label} />
                </label>

                <label class="admin-form__field">
                  <span>Meta labela taba</span>
                  <input class="input-control" data-scope-tab-field="tabMeta" value={tab.tabMeta} />
                </label>

                <div class="admin-inline-media-field admin-form__field--full">
                  <span>Ikonica</span>
                  <input
                    data-scope-tab-field="icon"
                    data-scope-tab-image-input="icon"
                    type="hidden"
                    value={tab.icon}
                  />
                  <div
                    class="admin-inline-media-field__preview"
                    data-scope-tab-image-preview="icon"
                  >
                    {tab.icon ? (
                      <img src={tab.icon} alt="" loading="lazy" />
                    ) : (
                      <p class="admin-inline-media-field__empty">Slika nije dodata.</p>
                    )}
                  </div>
                  <div class="admin-inline-media-field__actions">
                    <label class="button-secondary admin-inline-media-field__upload">
                      <span>Otpremi sliku</span>
                      <input accept="image/*" data-scope-tab-upload="icon" hidden type="file" />
                    </label>
                    <button
                      class="button-secondary"
                      data-scope-tab-image-clear="icon"
                      type="button"
                    >
                      Ukloni sliku
                    </button>
                  </div>
                  <div class="admin-upload-progress" data-scope-tab-image-progress="icon" hidden>
                    <div class="admin-upload-progress__track">
                      <div
                        class="admin-upload-progress__bar"
                        data-scope-tab-image-progress-bar="icon"
                        style="width: 0%;"
                      />
                    </div>
                  </div>
                  <p class="admin-inline-media-field__status" data-scope-tab-image-status="icon" />
                </div>

                <label class="admin-form__field">
                  <span>Naslov panela</span>
                  <input
                    class="input-control"
                    data-scope-tab-field="summaryTitle"
                    value={tab.summaryTitle}
                  />
                </label>

                <div class="admin-form__field admin-form__field--full">
                  <span>Kratki opis panela</span>
                  <div class="admin-scope-tab-rich-text" data-scope-tab-field="summaryCopy">
                    <textarea data-scope-tab-rtf-initial hidden>
                      {tab.summaryCopy}
                    </textarea>
                  </div>
                </div>

                <label class="admin-form__field">
                  <span>Eyebrow panela</span>
                  <input
                    class="input-control"
                    data-scope-tab-field="panelEyebrow"
                    value={tab.panelEyebrow}
                  />
                </label>

                <label class="admin-form__field">
                  <span>Labela statistike</span>
                  <input
                    class="input-control"
                    data-scope-tab-field="panelStatLabel"
                    value={tab.panelStatLabel}
                  />
                </label>

                <label class="admin-form__field">
                  <span>Labela CTA u panelu</span>
                  <input
                    class="input-control"
                    data-scope-tab-field="panelCtaLabel"
                    value={tab.panelCtaLabel}
                  />
                </label>

                <div class="admin-inline-media-field admin-form__field--full">
                  <span>Detalj slika</span>
                  <input
                    data-scope-tab-field="detailImage"
                    data-scope-tab-image-input="detailImage"
                    type="hidden"
                    value={tab.detailImage}
                  />
                  <div
                    class="admin-inline-media-field__preview"
                    data-scope-tab-image-preview="detailImage"
                  >
                    {tab.detailImage ? (
                      <img src={tab.detailImage} alt="" loading="lazy" />
                    ) : (
                      <p class="admin-inline-media-field__empty">Slika nije dodata.</p>
                    )}
                  </div>
                  <div class="admin-inline-media-field__actions">
                    <label class="button-secondary admin-inline-media-field__upload">
                      <span>Otpremi sliku</span>
                      <input
                        accept="image/*"
                        data-scope-tab-upload="detailImage"
                        hidden
                        type="file"
                      />
                    </label>
                    <button
                      class="button-secondary"
                      data-scope-tab-image-clear="detailImage"
                      type="button"
                    >
                      Ukloni sliku
                    </button>
                  </div>
                  <div
                    class="admin-upload-progress"
                    data-scope-tab-image-progress="detailImage"
                    hidden
                  >
                    <div class="admin-upload-progress__track">
                      <div
                        class="admin-upload-progress__bar"
                        data-scope-tab-image-progress-bar="detailImage"
                        style="width: 0%;"
                      />
                    </div>
                  </div>
                  <p
                    class="admin-inline-media-field__status"
                    data-scope-tab-image-status="detailImage"
                  />
                </div>

                <div class="admin-form__field admin-form__field--full">
                  <span>Opis bannera detail stranice</span>
                  <div
                    class="admin-scope-tab-rich-text"
                    data-scope-tab-field="detailBannerDescription"
                  >
                    <textarea data-scope-tab-rtf-initial hidden>
                      {tab.detailBannerDescription}
                    </textarea>
                  </div>
                </div>

                <label class="admin-form__field">
                  <span>Eyebrow detail stranice</span>
                  <input
                    class="input-control"
                    data-scope-tab-field="detailEyebrow"
                    value={tab.detailEyebrow}
                  />
                </label>

                <div class="admin-form__field admin-form__field--full">
                  <span>Lead tekst</span>
                  <div class="admin-scope-tab-rich-text" data-scope-tab-field="detailLead">
                    <textarea data-scope-tab-rtf-initial hidden>
                      {tab.detailLead}
                    </textarea>
                  </div>
                </div>

                <label class="admin-form__field">
                  <span>Labela nazad</span>
                  <input
                    class="input-control"
                    data-scope-tab-field="detailBackLabel"
                    value={tab.detailBackLabel}
                  />
                </label>

                <label class="admin-form__field">
                  <span>Labela CTA detail stranice</span>
                  <input
                    class="input-control"
                    data-scope-tab-field="detailCtaLabel"
                    value={tab.detailCtaLabel}
                  />
                </label>

                {tab.items.map((item, itemIndex) => (
                  <>
                    <label class="admin-form__field">
                      <span>Stavka {itemIndex + 1} naslov</span>
                      <input
                        class="input-control"
                        data-scope-tab-item-title
                        data-scope-tab-item-index={itemIndex}
                        value={item.title}
                      />
                    </label>

                    <div class="admin-form__field admin-form__field--full">
                      <span>Stavka {itemIndex + 1} opis</span>
                      <div
                        class="admin-scope-tab-item-rich-text"
                        data-scope-tab-item-copy
                        data-scope-tab-item-index={itemIndex}
                      >
                        <textarea data-scope-tab-rtf-initial hidden>
                          {item.copy}
                        </textarea>
                      </div>
                    </div>
                  </>
                ))}
              </div>
            </div>
          ))
        }
      </div>

      <div class="admin-form__actions" style="justify-content: flex-start;">
        <button class="button-secondary" type="button" data-scope-tab-add> Dodaj temu </button>
      </div>

      <template data-scope-tab-template>
        <div class="admin-section-group admin-form__field--full" data-scope-tab-item>
          <div
            style="display: flex; justify-content: space-between; gap: 0.75rem; align-items: center; flex-wrap: wrap;"
          >
            <h3 style="margin: 0;" data-scope-tab-title>Tema</h3>
            <button class="button-secondary" type="button" data-scope-tab-remove>
              Obriši temu
            </button>
          </div>

          <div class="admin-form__grid">
            <label class="admin-form__field">
              <span>Slug</span>
              <input class="input-control" data-scope-tab-field="id" />
            </label>

            <label class="admin-form__field">
              <span>Labela</span>
              <input class="input-control" data-scope-tab-field="label" />
            </label>

            <label class="admin-form__field">
              <span>Meta labela taba</span>
              <input class="input-control" data-scope-tab-field="tabMeta" />
            </label>

            <div class="admin-inline-media-field admin-form__field--full">
              <span>Ikonica</span>
              <input data-scope-tab-field="icon" data-scope-tab-image-input="icon" type="hidden" />
              <div class="admin-inline-media-field__preview" data-scope-tab-image-preview="icon">
                <p class="admin-inline-media-field__empty">Slika nije dodata.</p>
              </div>
              <div class="admin-inline-media-field__actions">
                <label class="button-secondary admin-inline-media-field__upload">
                  <span>Otpremi sliku</span>
                  <input accept="image/*" data-scope-tab-upload="icon" hidden type="file" />
                </label>
                <button class="button-secondary" data-scope-tab-image-clear="icon" type="button">
                  Ukloni sliku
                </button>
              </div>
              <div class="admin-upload-progress" data-scope-tab-image-progress="icon" hidden>
                <div class="admin-upload-progress__track">
                  <div
                    class="admin-upload-progress__bar"
                    data-scope-tab-image-progress-bar="icon"
                    style="width: 0%;"
                  >
                  </div>
                </div>
              </div>
              <p class="admin-inline-media-field__status" data-scope-tab-image-status="icon"></p>
            </div>

            <label class="admin-form__field">
              <span>Naslov panela</span>
              <input class="input-control" data-scope-tab-field="summaryTitle" />
            </label>

            <div class="admin-form__field admin-form__field--full">
              <span>Kratki opis panela</span>
              <div class="admin-scope-tab-rich-text" data-scope-tab-field="summaryCopy">
                <textarea data-scope-tab-rtf-initial hidden></textarea>
              </div>
            </div>

            <label class="admin-form__field">
              <span>Eyebrow panela</span>
              <input class="input-control" data-scope-tab-field="panelEyebrow" />
            </label>

            <label class="admin-form__field">
              <span>Labela statistike</span>
              <input class="input-control" data-scope-tab-field="panelStatLabel" />
            </label>

            <label class="admin-form__field">
              <span>Labela CTA u panelu</span>
              <input class="input-control" data-scope-tab-field="panelCtaLabel" />
            </label>

            <div class="admin-inline-media-field admin-form__field--full">
              <span>Detalj slika</span>
              <input
                data-scope-tab-field="detailImage"
                data-scope-tab-image-input="detailImage"
                type="hidden"
              />
              <div
                class="admin-inline-media-field__preview"
                data-scope-tab-image-preview="detailImage"
              >
                <p class="admin-inline-media-field__empty">Slika nije dodata.</p>
              </div>
              <div class="admin-inline-media-field__actions">
                <label class="button-secondary admin-inline-media-field__upload">
                  <span>Otpremi sliku</span>
                  <input accept="image/*" data-scope-tab-upload="detailImage" hidden type="file" />
                </label>
                <button
                  class="button-secondary"
                  data-scope-tab-image-clear="detailImage"
                  type="button"
                >
                  Ukloni sliku
                </button>
              </div>
              <div class="admin-upload-progress" data-scope-tab-image-progress="detailImage" hidden>
                <div class="admin-upload-progress__track">
                  <div
                    class="admin-upload-progress__bar"
                    data-scope-tab-image-progress-bar="detailImage"
                    style="width: 0%;"
                  >
                  </div>
                </div>
              </div>
              <p class="admin-inline-media-field__status" data-scope-tab-image-status="detailImage">
              </p>
            </div>

            <div class="admin-form__field admin-form__field--full">
              <span>Opis bannera detail stranice</span>
              <div class="admin-scope-tab-rich-text" data-scope-tab-field="detailBannerDescription">
                <textarea data-scope-tab-rtf-initial hidden></textarea>
              </div>
            </div>

            <label class="admin-form__field">
              <span>Eyebrow detail stranice</span>
              <input class="input-control" data-scope-tab-field="detailEyebrow" />
            </label>

            <div class="admin-form__field admin-form__field--full">
              <span>Lead tekst</span>
              <div class="admin-scope-tab-rich-text" data-scope-tab-field="detailLead">
                <textarea data-scope-tab-rtf-initial hidden></textarea>
              </div>
            </div>

            <label class="admin-form__field">
              <span>Labela nazad</span>
              <input class="input-control" data-scope-tab-field="detailBackLabel" />
            </label>

            <label class="admin-form__field">
              <span>Labela CTA detail stranice</span>
              <input class="input-control" data-scope-tab-field="detailCtaLabel" />
            </label>

            {
              [0, 1, 2].map((itemIndex) => (
                <>
                  <label class="admin-form__field">
                    <span>Stavka {itemIndex + 1} naslov</span>
                    <input
                      class="input-control"
                      data-scope-tab-item-title
                      data-scope-tab-item-index={itemIndex}
                    />
                  </label>

                  <div class="admin-form__field admin-form__field--full">
                    <span>Stavka {itemIndex + 1} opis</span>
                    <div
                      class="admin-scope-tab-item-rich-text"
                      data-scope-tab-item-copy
                      data-scope-tab-item-index={itemIndex}
                    >
                      <textarea data-scope-tab-rtf-initial hidden />
                    </div>
                  </div>
                </>
              ))
            }
          </div>
        </div>
      </template>
    </div>
  </div>
</div>
