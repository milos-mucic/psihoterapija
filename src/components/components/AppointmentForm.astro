---
import SubmissionForm from "@/components/components/SubmissionForm.astro";

type Props = {
  locale: "sr-latn" | "sr-cyrl";
  formatLabel: string;
  formats: string[];
  labels: {
    name: string;
    email: string;
    phone: string;
    message: string;
    formatLabel: string;
    chooseOption: string;
    submitAppointment: string;
    success: string;
    error: string;
  };
};

const { locale, labels, formatLabel, formats } = Astro.props;
---

<SubmissionForm
  locale={locale}
  type="appointment"
  submitLabel={labels.submitAppointment}
  formatLabel={formatLabel}
  appointmentFormats={formats}
  labels={labels}
/>
