                      <label class="admin-form__field">
                        <span>Format {index + 1}</span>
                        <input
                          class="input-control"
                          name={`bookingFormat${index + 1}`}
                          value={format}
                        />
                      </label>
                    ))}
                  </div>
                </div>
              </div>

              <div
                class="card"
                style="padding: 1.5rem;"
                data-section-preview
                data-section-preview-fragment="appointment-faq"
              >
                <div class="page-grid">
                  <div>
                    <h2 style="margin: 0;">FAQ</h2>
                    <p class="section-copy">Slika i četiri pitanja na dnu stranice.</p>
                  </div>

                  <div class="admin-form__grid">
                    <AdminMediaField
                      client:load
                      name="faqImage"
                      label="FAQ slika"
                      initialValue={pageContent.faq.image}
                      uploadUrl="/api/admin/media/upload"
                      uploadFolder="pages/appointment"
                      uploadLabel="Otpremi sliku"
                    />

                    {pageContent.faq.items.map((item, index) => (
                      <div class="admin-section-group admin-form__field--full">
                        <h3 style="margin: 0;">Pitanje {index + 1}</h3>
                        <div class="admin-form__grid">
                          <label class="admin-form__field admin-form__field--full">
                            <span>Pitanje</span>
                            <input
                              class="input-control"
                              name={`faq${index + 1}Question`}
                              value={item.question}
                            />
                          </label>

                          <div class="admin-form__field admin-form__field--full">
                            <span>Odgovor</span>
                            <AdminRichTextField
                              client:load
                              name={`faq${index + 1}Answer`}
                              initialValue={item.answer}
                              uploadUrl="/api/admin/media/upload"
                              uploadFolder="pages/appointment"
                              labels={richTextLabels}
                            />
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </>
          );
        })()
      : null
  }

  {
    page === "faq"
      ? (() => {
          const pageContent = content as FaqPageManagedContent;

          return (
            <>
              <div
                class="card"
                style="padding: 1.5rem;"
                data-section-preview
                data-section-preview-fragment="faq-banner"
              >
                <div class="page-grid">
                  <div>
                    <h2 style="margin: 0;">Banner</h2>
                    <p class="section-copy">Naslov, SEO opis i pozadinska slika FAQ stranice.</p>
                  </div>

                  <div class="admin-form__grid">
                    <label class="admin-form__field">
                      <span>Naslov</span>
                      <input
                        class="input-control"
                        name="bannerTitle"
                        value={pageContent.banner.title}
                      />
                    </label>

                    <div class="admin-form__field admin-form__field--full">
                      <span>Opis</span>
                      <AdminRichTextField
                        client:load
                        name="bannerDescription"
                        initialValue={pageContent.banner.description}
                        uploadUrl="/api/admin/media/upload"
                        uploadFolder="pages/faq"
                        labels={richTextLabels}
                      />
                    </div>

                    <AdminMediaField
                      client:load
                      name="bannerBackgroundImage"
                      label="Pozadinska slika"
                      initialValue={pageContent.banner.backgroundImage}
                      uploadUrl="/api/admin/media/upload"
                      uploadFolder="pages/faq"
                      uploadLabel="Otpremi sliku"
                    />
                  </div>
                </div>
              </div>

              <div
                class="card"
                style="padding: 1.5rem;"
                data-section-preview
                data-section-preview-fragment="faq-items"
              >
                <div class="page-grid">
                  <div>
                    <h2 style="margin: 0;">FAQ pitanja</h2>
                    <p class="section-copy">Slika i četiri glavna pitanja.</p>
                  </div>

                  <div class="admin-form__grid">
                    <AdminMediaField
                      client:load
                      name="faqImage"
                      label="FAQ slika"
                      initialValue={pageContent.faq.image}
                      uploadUrl="/api/admin/media/upload"
                      uploadFolder="pages/faq"
                      uploadLabel="Otpremi sliku"
                    />

                    {pageContent.faq.items.map((item, index) => (
                      <div class="admin-section-group admin-form__field--full">
                        <h3 style="margin: 0;">Pitanje {index + 1}</h3>
                        <div class="admin-form__grid">
                          <label class="admin-form__field admin-form__field--full">
                            <span>Pitanje</span>
                            <input
                              class="input-control"
                              name={`faq${index + 1}Question`}
                              value={item.question}
                            />
                          </label>

                          <div class="admin-form__field admin-form__field--full">
                            <span>Odgovor</span>
                            <AdminRichTextField
                              client:load
                              name={`faq${index + 1}Answer`}
                              initialValue={item.answer}
                              uploadUrl="/api/admin/media/upload"
                              uploadFolder="pages/faq"
                              labels={richTextLabels}
                            />
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              <div
                class="card"
                style="padding: 1.5rem;"
                data-section-preview
                data-section-preview-fragment="faq-booking"
              >
                <div class="page-grid">
                  <div>
                    <h2 style="margin: 0;">Zakazivanje blok</h2>
                    <p class="section-copy">Tekst i formati rada ispod FAQ liste.</p>
                  </div>

                  <div class="admin-form__grid">
                    <label class="admin-form__field admin-form__field--full">
                      <span>Naslov</span>
                      <input
                        class="input-control"
                        name="bookingTitle"
                        value={pageContent.booking.title}
                      />
                    </label>

                    <div class="admin-form__field admin-form__field--full">
                      <span>Opis</span>
                      <AdminRichTextField
                        client:load
                        name="bookingCopy"
                        initialValue={pageContent.booking.copy}
                        uploadUrl="/api/admin/media/upload"
                        uploadFolder="pages/faq"
                        labels={richTextLabels}
                      />
                    </div>

                    <label class="admin-form__field">
                      <span>Labela formata</span>
                      <input
                        class="input-control"
                        name="bookingFormatLabel"
                        value={pageContent.booking.formatLabel}
                      />
                    </label>

                    {pageContent.booking.formats.map((format, index) => (
                      <label class="admin-form__field">
                        <span>Format {index + 1}</span>
                        <input
                          class="input-control"
                          name={`bookingFormat${index + 1}`}
                          value={format}
                        />
                      </label>
                    ))}
                  </div>
                </div>
              </div>
            </>
          );
        })()
      : null
  }

  <div class="admin-form__actions admin-form__actions--floating">
    <p class="admin-form__save-status" data-admin-form-submit-status aria-live="polite"></p>
    <button class="button-primary admin-form__fab" type="submit" data-admin-form-submit>
      Sačuvaj stranicu
    </button>
  </div>
</form>

<script>
  import { mountAdminRichTextField, unmountAdminRichTextField } from "./AdminRichTextMount";
  import { uploadWithProgress } from "@/lib/http/upload-with-progress";

  (() => {
    const setupFloatingSubmit = () => {
      document.querySelectorAll("[data-admin-section-preview-root]").forEach((form) => {
        if (!(form instanceof HTMLFormElement) || form.dataset.floatingSubmitBound === "true") {
          return;
        }

        const submitButtons = Array.from(form.querySelectorAll("[data-admin-form-submit]")).filter(
          (button) => button instanceof HTMLButtonElement,
        );
        const statusNodes = Array.from(
          form.querySelectorAll("[data-admin-form-submit-status]"),
        ).filter((node) => node instanceof HTMLElement);
        const pendingSources = new Map();
        let autoSaveRequested = false;
        let isSubmitting = false;

        const syncSubmitState = () => {
          const hasPending = pendingSources.size > 0;
          const message = isSubmitting
            ? "Čuvanje u toku..."
            : autoSaveRequested && hasPending
              ? "Završavam upload pa čuvam izmenu slike."
              : autoSaveRequested
                ? "Čuvam izmenu slike..."
                : hasPending
                  ? "Sačekajte da se obrada slike ili videa završi."
                  : "Sve media izmene su spremne za čuvanje.";

          form.dataset.pendingUploads = hasPending ? "true" : "false";

          submitButtons.forEach((button) => {
            button.disabled = hasPending;
            button.setAttribute("aria-disabled", hasPending ? "true" : "false");
          });

          statusNodes.forEach((node) => {
            node.textContent = message;
            node.dataset.tone = hasPending ? "muted" : "ready";
          });
        };

        const tryAutoSave = () => {
          if (!autoSaveRequested || isSubmitting || form.dataset.pendingUploads === "true") {
            return;
          }

          if (!form.checkValidity()) {
            autoSaveRequested = false;
            syncSubmitState();
            return;
          }

          requestAnimationFrame(() => form.requestSubmit());
        };

        form.addEventListener("admin:pending-media", (event) => {
          if (!(event instanceof CustomEvent)) {
            return;
          }

          const sourceId =
            typeof event.detail?.sourceId === "string" ? event.detail.sourceId : undefined;

          if (!sourceId) {
            return;
          }

          if (event.detail?.active) {
            pendingSources.set(sourceId, true);
          } else {
            pendingSources.delete(sourceId);
          }

          syncSubmitState();
          tryAutoSave();
        });

        form.addEventListener("admin:auto-save-media", () => {
          autoSaveRequested = true;
          syncSubmitState();
          tryAutoSave();
        });

        form.addEventListener("submit", (event) => {
          if (form.dataset.pendingUploads === "true") {
            event.preventDefault();
            syncSubmitState();
            return;
          }

          if (isSubmitting) {
            event.preventDefault();
            return;
          }

          isSubmitting = true;
          syncSubmitState();
        });

        syncSubmitState();
        form.dataset.floatingSubmitBound = "true";
      });
    };

    const setupSectionPreviews = () => {
      document.querySelectorAll("[data-admin-section-preview-root]").forEach((form) => {
        if (!(form instanceof HTMLFormElement) || form.dataset.sectionPreviewBound === "true") {
          return;
        }

        const baseHref = form.dataset.previewBaseHref ?? "";
        const editorRoot = form.closest("[data-admin-page-editor]");
        const nav = editorRoot?.querySelector("[data-admin-section-nav]");
        const previewFrame = editorRoot?.querySelector("[data-admin-preview-iframe]");
        const previewLink = editorRoot?.querySelector("[data-admin-preview-open]");
        const sections = Array.from(form.children).filter(
          (child) => child instanceof HTMLElement && child.matches("[data-section-preview]"),
        );

        const activateSection = (nextIndex) => {
          sections.forEach((section, index) => {
            if (!(section instanceof HTMLElement)) {
              return;
            }

            const isActive = index === nextIndex;
            section.classList.toggle("is-active", isActive);
            section.classList.toggle("is-collapsed", !isActive);

            const navButton = nav?.querySelector(`[data-admin-section-nav-index="${index}"]`);
            navButton?.classList.toggle("is-active", isActive);
            navButton?.setAttribute("aria-current", isActive ? "true" : "false");
          });

          const activeSection = sections[nextIndex];
          if (!(activeSection instanceof HTMLElement)) {
            return;
          }

          const fragment = activeSection.dataset.sectionPreviewFragment ?? "";
          const href = fragment ? `${baseHref}#${fragment}` : baseHref;

          if (previewFrame instanceof HTMLIFrameElement && previewFrame.src !== href) {
            previewFrame.src = href;
          }

          if (previewLink instanceof HTMLAnchorElement) {
            previewLink.href = href;
          }
        };

        sections.forEach((child, index) => {
          if (!(child instanceof HTMLElement) || !child.matches("[data-section-preview]")) {
            return;
          }

          const fragment = child.dataset.sectionPreviewFragment ?? "";
          const href = fragment ? `${baseHref}#${fragment}` : baseHref;
          const title =
            child.dataset.sectionPreviewTitle ??
            child.querySelector("h2")?.textContent?.trim() ??
            "Preview sekcije";
          const copy =
            child.dataset.sectionPreviewCopy ??
            child.querySelector(".section-copy")?.textContent?.trim() ??
            "";

          child.classList.add("admin-section-editor");
          child.classList.toggle("is-active", index === 0);
          child.classList.toggle("is-collapsed", index !== 0);

          const existingNodes = Array.from(child.childNodes);
          const body = document.createElement("div");
          body.className = "admin-section-editor__body";
          existingNodes.forEach((node) => body.append(node));

          const header = document.createElement("div");
          header.className = "admin-section-editor__header";

          const badge = document.createElement("span");
          badge.className = "admin-section-editor__badge";
          badge.textContent = String(index + 1).padStart(2, "0");

          const meta = document.createElement("div");
          meta.className = "admin-section-editor__meta";

          const heading = document.createElement("h2");
          heading.textContent = title;
          meta.append(heading);

          if (copy) {
            const summary = document.createElement("p");
            summary.className = "admin-section-editor__copy";
            summary.textContent = copy;
            meta.append(summary);
          }

          const actions = document.createElement("div");
          actions.className = "admin-section-editor__actions";

          const toggle = document.createElement("button");
          toggle.type = "button";
          toggle.className = "button-primary admin-section-editor__toggle";
          toggle.textContent = "Uredi sekciju";
          toggle.addEventListener("click", () => activateSection(index));

          const link = document.createElement("a");
          link.className = "button-secondary";
          link.href = href;
          link.target = "_blank";
          link.rel = "noreferrer";
          link.textContent = "Otvori javnu sekciju";

          actions.append(toggle, link);
          header.append(badge, meta, actions);

          child.replaceChildren(header, body);

          if (nav instanceof HTMLElement) {
            const navButton = document.createElement("button");
            navButton.type = "button";
            navButton.className = `admin-section-nav__button${index === 0 ? " is-active" : ""}`;
            navButton.dataset.adminSectionNavIndex = String(index);

            const navIndex = document.createElement("span");
            navIndex.className = "admin-section-nav__index";
            navIndex.textContent = String(index + 1).padStart(2, "0");

            const navTitle = document.createElement("span");
            navTitle.className = "admin-section-nav__title";
            navTitle.textContent = title;

            navButton.append(navIndex, navTitle);

            if (copy) {
              const navCopy = document.createElement("span");
              navCopy.className = "admin-section-nav__copy";
              navCopy.textContent = copy;
              navButton.append(navCopy);
            }

            navButton.addEventListener("click", () => activateSection(index));
            nav.append(navButton);
          }

          child.addEventListener(
            "invalid",
            (event) => {
              if (event.target instanceof HTMLElement) {
                activateSection(index);
              }
            },
            true,
          );
        });

        activateSection(0);
        form.dataset.sectionPreviewBound = "true";
      });
    };

    const setupBiographyCards = () => {
      const list = document.querySelector("[data-biography-card-list]");
      const template = document.querySelector("[data-biography-card-template]");
      const addButton = document.querySelector("[data-biography-card-add]");
      const form = list?.closest("form");

      if (
        !(list instanceof HTMLElement) ||
        !(template instanceof HTMLTemplateElement) ||
        !(addButton instanceof HTMLButtonElement) ||
        !(form instanceof HTMLFormElement) ||
        list.dataset.bound === "true"
      ) {
        return;
      }

      let richTextLabels = {};

      try {
        richTextLabels = JSON.parse(list.dataset.biographyCardRichTextLabels ?? "{}");
      } catch {
        richTextLabels = {};
      }

      const getPendingSourceId = (card) => {
        if (!(card instanceof HTMLElement)) {
          return "";
        }

        if (!card.dataset.pendingSourceId) {
          card.dataset.pendingSourceId =
            globalThis.crypto?.randomUUID?.() ?? `bio-card-${Date.now()}-${Math.random()}`;
        }

        return card.dataset.pendingSourceId;
      };

      const setPendingUpload = (card, active) => {
        const sourceId = getPendingSourceId(card);

        if (!sourceId) {
          return;
        }

        form.dispatchEvent(
          new CustomEvent("admin:pending-media", {
            detail: { active, sourceId },
          }),
        );
      };

      const createEmptyImageState = () => {
        const empty = document.createElement("p");
        empty.className = "admin-inline-media-field__empty";
        empty.textContent = "Slika nije dodata.";
        return empty;
      };

      const getCardImageField = (card) => {
        const field = card.querySelector("[data-biography-card-image-input]");
        return field instanceof HTMLInputElement ? field : null;
      };

      const getCardImagePreview = (card) => {
        const preview = card.querySelector("[data-biography-card-image-preview]");
        return preview instanceof HTMLElement ? preview : null;
      };

      const getCardImageStatus = (card) => {
        const status = card.querySelector("[data-biography-card-image-status]");
        return status instanceof HTMLElement ? status : null;
      };

      const updateCardImagePreview = (card) => {
        const field = getCardImageField(card);
        const preview = getCardImagePreview(card);

        if (!field || !preview) {
          return;
        }

        preview.replaceChildren();

        if (field.value.trim()) {
          const image = document.createElement("img");
          image.src = field.value.trim();
          image.alt = "";
          image.loading = "lazy";
          preview.append(image);
        } else {
          preview.append(createEmptyImageState());
        }

        const clearButton = card.querySelector("[data-biography-card-image-clear]");

        if (clearButton instanceof HTMLButtonElement) {
          clearButton.disabled = field.value.trim().length === 0;
        }
      };

      const setCardImageStatus = (card, message = "") => {
        const status = getCardImageStatus(card);

        if (status) {
          status.textContent = message;
        }
      };

      const setCardImageProgress = (card, percent = 0) => {
        const progress = card.querySelector("[data-biography-card-image-progress]");
        const bar = card.querySelector("[data-biography-card-image-progress-bar]");

        if (progress instanceof HTMLElement) {
          progress.hidden = false;
        }

        if (bar instanceof HTMLElement) {
          bar.style.width = `${percent}%`;
        }
      };

      const clearCardImageProgress = (card) => {
        const progress = card.querySelector("[data-biography-card-image-progress]");
        const bar = card.querySelector("[data-biography-card-image-progress-bar]");

        if (progress instanceof HTMLElement) {
          progress.hidden = true;
        }

        if (bar instanceof HTMLElement) {
          bar.style.width = "0%";
        }
      };

      const mountCardRichText = (field, index) => {
        if (!(field instanceof HTMLElement)) {
          return;
        }

        const fieldName = field.dataset.biographyCardField;

        if (!fieldName) {
          return;
        }

        const initialField = field.querySelector("[data-biography-card-rtf-initial]");
        const initialValue = initialField instanceof HTMLTextAreaElement ? initialField.value : "";

        mountAdminRichTextField(field, {
          initialValue,
          labels: richTextLabels,
          name: `biographyCard_${index}_${fieldName}`,
          uploadFolder: "pages/biography",
          uploadUrl: "/api/admin/media/upload",
        });
      };

      const uploadCardImage = async (card, file) => {
        const field = getCardImageField(card);

        if (!field) {
          return;
        }

        const formData = new FormData();
        formData.append("file", file);
        formData.append("folder", "pages/biography");

        setCardImageStatus(card, "Otpremanje...");
        setCardImageProgress(card, 0);
        setPendingUpload(card, true);

        try {
          const data = await uploadWithProgress({
            formData,
            url: "/api/admin/media/upload",
            onProgress: (percent) => {
              setCardImageProgress(card, percent);
              setCardImageStatus(card, `Otpremanje... ${percent}%`);
            },
          });

          if (!data?.url || typeof data.url !== "string") {
            setCardImageStatus(card, "Upload nije uspeo.");
            clearCardImageProgress(card);
            return;
          }

          field.value = data.url;
          updateCardImagePreview(card);
          setCardImageStatus(card, "Slika je otpremljena.");
          setCardImageProgress(card, 100);
          form.dispatchEvent(
            new CustomEvent("admin:auto-save-media", {
              detail: { sourceId: getPendingSourceId(card) },
            }),
          );
        } catch {
          setCardImageStatus(card, "Upload nije uspeo.");
          clearCardImageProgress(card);
        } finally {
          setPendingUpload(card, false);
        }
      };

      const syncCards = () => {
        const items = Array.from(list.querySelectorAll("[data-biography-card-item]"));

        items.forEach((item, index) => {
          if (!(item instanceof HTMLElement)) {
            return;
          }

          const title = item.querySelector("[data-biography-card-title]");

          if (title instanceof HTMLElement) {
            title.textContent = `Profil ${index + 1}`;
          }

          const removeButton = item.querySelector("[data-biography-card-remove]");

          if (removeButton instanceof HTMLButtonElement) {
            removeButton.disabled = items.length === 1;
          }

          item.querySelectorAll("[data-biography-card-field]").forEach((field) => {
            const fieldName = field.dataset.biographyCardField;

            if (!fieldName) {
              return;
            }

            if (field.classList.contains("admin-biography-card-rich-text")) {
              mountCardRichText(field, index);
              return;
            }

            if (!(field instanceof HTMLInputElement) && !(field instanceof HTMLTextAreaElement)) {
              return;
            }

            field.name = `biographyCard_${index}_${fieldName}`;
          });

          updateCardImagePreview(item);
        });
      };

      addButton.addEventListener("click", () => {
        list.append(template.content.cloneNode(true));
        syncCards();
      });

      list.addEventListener("click", (event) => {
        const target = event.target;

        if (!(target instanceof HTMLElement)) {
          return;
        }

        const clearButton = target.closest("[data-biography-card-image-clear]");

        if (clearButton instanceof HTMLButtonElement) {
          const card = clearButton.closest("[data-biography-card-item]");

          if (!(card instanceof HTMLElement)) {
            return;
          }

          const field = getCardImageField(card);

          if (!field) {
            return;
          }

          field.value = "";
          setCardImageStatus(card, "");
          clearCardImageProgress(card);
          updateCardImagePreview(card);
          return;
        }

        const removeButton = target.closest("[data-biography-card-remove]");

        if (!(removeButton instanceof HTMLButtonElement)) {
          return;
        }

        const items = list.querySelectorAll("[data-biography-card-item]");

        if (items.length <= 1) {
          return;
        }

        const card = removeButton.closest("[data-biography-card-item]");

        if (card instanceof HTMLElement) {
          card.querySelectorAll(".admin-biography-card-rich-text").forEach((field) => {
            if (field instanceof HTMLElement) {
              unmountAdminRichTextField(field);
            }
          });
          setPendingUpload(card, false);
          card.remove();
          syncCards();
        }
      });

      list.addEventListener("change", (event) => {
        const target = event.target;

        if (
          !(target instanceof HTMLInputElement) ||
          !target.matches("[data-biography-card-upload]")
        ) {
          return;
        }

        const file = target.files?.[0];
        const card = target.closest("[data-biography-card-item]");

        target.value = "";

        if (!file || !(card instanceof HTMLElement)) {
          return;
        }

        void uploadCardImage(card, file);
      });

      syncCards();
      list.dataset.bound = "true";
    };

    setupFloatingSubmit();
    setupSectionPreviews();
    setupBiographyCards();
    document.addEventListener("astro:page-load", setupFloatingSubmit);
    document.addEventListener("astro:page-load", setupSectionPreviews);
    document.addEventListener("astro:page-load", setupBiographyCards);
  })();
</script>
