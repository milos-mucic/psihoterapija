---
import { AdminMediaField } from "@/components/components/AdminMediaField";
import { AdminRichTextField } from "@/components/components/AdminRichTextField";
import type {
  AboutPageManagedContent,
  AppointmentPageManagedContent,
  BiographyPageManagedContent,
  FaqPageManagedContent,
  PageKey,
  PricingPageManagedContent,
  PsychotherapyPageManagedContent,
  ScopePageManagedContent,
} from "@/features/page-content/types/page-content.types";
import type { SiteLocale } from "@/lib/config/site";

type SupportedPage = Exclude<PageKey, "home">;

type Props = {
  action: string;
  page: SupportedPage;
  content:
    | AboutPageManagedContent
    | BiographyPageManagedContent
    | PsychotherapyPageManagedContent
    | ScopePageManagedContent
    | PricingPageManagedContent
    | AppointmentPageManagedContent
    | FaqPageManagedContent;
  locale: SiteLocale;
  previewBaseHref: string;
  localeLabel: string;
};

const { action, content, locale, page, previewBaseHref, localeLabel } = Astro.props;
const richTextLabels = {
  bold: "Bold",
  italic: "Italic",
  underline: "Underline",
  heading2: "Heading 2",
  heading3: "Heading 3",
  bulletList: "Lista",
  orderedList: "Numerisana lista",
  quote: "Citat",
  link: "Link",
  image: "Slika",
  clear: "Ukloni format",
  uploadFailed: "Upload slike nije uspeo.",
};
---

<form
  class="admin-form"
  method="post"
  action={action}
  data-admin-section-preview-root
  data-preview-base-href={previewBaseHref}
  data-preview-locale-label={localeLabel}
>
  <input type="hidden" name="locale" value={locale} />

  {
    page === "about"
      ? (() => {
          const pageContent = content as AboutPageManagedContent;

          return (
            <>
              <div
                class="card"
                style="padding: 1.5rem;"
                data-section-preview
                data-section-preview-fragment="about-banner"
              >
                <div class="page-grid">
                  <div>
                    <h2 style="margin: 0;">Banner</h2>
                    <p class="section-copy">Naslov, opis i pozadinska slika vrha stranice.</p>
                  </div>

                  <div class="admin-form__grid">
                    <label class="admin-form__field">
                      <span>Naslov</span>
                      <input
                        class="input-control"
                        name="bannerTitle"
                        value={pageContent.banner.title}
                      />
                    </label>

                    <div class="admin-form__field">
                      <span>Opis</span>
                      <AdminRichTextField
                        client:load
                        name="bannerDescription"
                        initialValue={pageContent.banner.description}
                        uploadUrl="/api/admin/media/upload"
                        uploadFolder="pages/about"
                        labels={richTextLabels}
                      />
                    </div>

                    <AdminMediaField
                      client:load
                      name="bannerBackgroundImage"
                      label="Pozadinska slika"
                      initialValue={pageContent.banner.backgroundImage}
                      uploadUrl="/api/admin/media/upload"
                      uploadFolder="pages/about"
                      uploadLabel="Otpremi sliku"
                    />
                  </div>
                </div>
              </div>

              <div
                class="card"
                style="padding: 1.5rem;"
                data-section-preview
                data-section-preview-fragment="about-showcase"
              >
                <div class="page-grid">
                  <div>
                    <h2 style="margin: 0;">Video i kartice</h2>
                    <p class="section-copy">Video prikaz i tri kartice ispod njega.</p>
                  </div>

                  <div class="admin-form__grid">
                    <label class="admin-form__field admin-form__field--full">
                      <span>Naslov sekcije</span>
                      <input
                        class="input-control"
                        name="showcaseTitle"
                        value={pageContent.showcase.title}
                      />
                    </label>

                    <label class="admin-form__field admin-form__field--full">
                      <span>Video URL</span>
                      <input
                        class="input-control"
                        name="showcaseVideoUrl"
                        value={pageContent.showcase.videoUrl}
                      />
                    </label>

                    <AdminMediaField
                      client:load
                      name="showcaseVideoImage"
                      label="Poster slika videa"
                      initialValue={pageContent.showcase.videoImage}
                      uploadUrl="/api/admin/media/upload"
                      uploadFolder="pages/about"
                      uploadLabel="Otpremi sliku"
                    />

                    {pageContent.showcase.cards.map((card, index) => (
                      <div class="admin-section-group admin-form__field--full">
                        <h3 style="margin: 0;">Kartica {index + 1}</h3>
                        <div class="admin-form__grid">
                          <label class="admin-form__field">
                            <span>Naslov</span>
                            <input
                              class="input-control"
                              name={`showcaseCard${index + 1}Title`}
                              value={card.title}
                            />
                          </label>

                          <div class="admin-form__field admin-form__field--full">
                            <span>Opis</span>
                            <AdminRichTextField
                              client:load
                              name={`showcaseCard${index + 1}Copy`}
                              initialValue={card.copy}
                              uploadUrl="/api/admin/media/upload"
                              uploadFolder="pages/about"
                              labels={richTextLabels}
                            />
                          </div>

                          <AdminMediaField
                            client:load
                            name={`showcaseCard${index + 1}Image`}
                            label="Slika"
                            initialValue={card.image}
                            uploadUrl="/api/admin/media/upload"
                            uploadFolder="pages/about"
                            uploadLabel="Otpremi sliku"
                          />
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              <div
                class="card"
                style="padding: 1.5rem;"
                data-section-preview
                data-section-preview-fragment="about-idea"
              >
                <div class="page-grid">
                  <div>
                    <h2 style="margin: 0;">Glavna ideja</h2>
                    <p class="section-copy">Naslov i rich text sadržaj centralnog objašnjenja.</p>
                  </div>

                  <div class="admin-form__grid">
                    <label class="admin-form__field admin-form__field--full">
                      <span>Naslov</span>
                      <input
                        class="input-control"
                        name="ideaTitle"
                        value={pageContent.idea.title}
                      />
                    </label>

                    <div class="admin-form__field admin-form__field--full">
                      <span>Sadržaj</span>
                      <AdminRichTextField
                        client:load
                        name="ideaBody"
                        initialValue={pageContent.idea.body}
                        uploadUrl="/api/admin/media/upload"
                        uploadFolder="pages/about"
                        labels={richTextLabels}
                      />
                    </div>
                  </div>
                </div>
              </div>

              <div
                class="card"
                style="padding: 1.5rem;"
                data-section-preview
                data-section-preview-fragment="about-idea"
              >
                <div class="page-grid">
                  <div>
                    <h2 style="margin: 0;">Fokus</h2>
                    <p class="section-copy">Naslov i pet stavki u bočnoj kartici.</p>
                  </div>

                  <div class="admin-form__grid">
                    <label class="admin-form__field admin-form__field--full">
                      <span>Naslov</span>
                      <input
                        class="input-control"
                        name="focusTitle"
                        value={pageContent.focus.title}
                      />
                    </label>

                    {pageContent.focus.items.map((item, index) => (
                      <label class="admin-form__field">
                        <span>Stavka {index + 1}</span>
                        <input class="input-control" name={`focusItem${index + 1}`} value={item} />
                      </label>
                    ))}
                  </div>
                </div>
              </div>

              <div
                class="card"
                style="padding: 1.5rem;"
                data-section-preview
                data-section-preview-fragment="about-blog"
              >
                <div class="page-grid">
                  <div>
                    <h2 style="margin: 0;">Blog sekcija</h2>
                    <p class="section-copy">Tekstualni blok iznad poslednjih blog postova.</p>
                  </div>

                  <div class="admin-form__grid">
                    <label class="admin-form__field">
                      <span>Naslov</span>
                      <input
                        class="input-control"
                        name="recentTitle"
                        value={pageContent.recent.title}
                      />
                    </label>

                    <label class="admin-form__field">
                      <span>Labela dugmeta</span>
                      <input
                        class="input-control"
                        name="recentLabel"
                        value={pageContent.recent.label}
                      />
                    </label>

                    <div class="admin-form__field admin-form__field--full">
                      <span>Opis</span>
                      <AdminRichTextField
                        client:load
                        name="recentCopy"
                        initialValue={pageContent.recent.copy}
                        uploadUrl="/api/admin/media/upload"
                        uploadFolder="pages/about"
                        labels={richTextLabels}
                      />
                    </div>

                    <label class="admin-form__field admin-form__field--full">
                      <span>Poruka kada nema postova</span>
                      <textarea
                        class="input-control input-control--textarea"
                        name="recentEmpty"
                        rows={2}
                      >
                        {pageContent.recent.empty}
                      </textarea>
                    </label>
                  </div>
                </div>
              </div>
            </>
          );
        })()
      : null
  }

  {
    page === "biography"
      ? (() => {
          const pageContent = content as BiographyPageManagedContent;

          return (
            <>
              <div
                class="card"
                style="padding: 1.5rem;"
                data-section-preview
                data-section-preview-fragment="biography-banner"
              >
                <div class="page-grid">
                  <div>
                    <h2 style="margin: 0;">Banner</h2>
                    <p class="section-copy">Naslovna sekcija biografije.</p>
                  </div>

                  <div class="admin-form__grid">
                    <label class="admin-form__field">
                      <span>Naslov</span>
                      <input
                        class="input-control"
                        name="bannerTitle"
                        value={pageContent.banner.title}
                      />
                    </label>

                    <div class="admin-form__field">
                      <span>Opis</span>
                      <AdminRichTextField
                        client:load
                        name="bannerDescription"
                        initialValue={pageContent.banner.description}
                        uploadUrl="/api/admin/media/upload"
                        uploadFolder="pages/biography"
                        labels={richTextLabels}
                      />
                    </div>

                    <AdminMediaField
                      client:load
                      name="bannerBackgroundImage"
                      label="Pozadinska slika"
                      initialValue={pageContent.banner.backgroundImage}
                      uploadUrl="/api/admin/media/upload"
                      uploadFolder="pages/biography"
                      uploadLabel="Otpremi sliku"
                    />
                  </div>
                </div>
              </div>

              <div
                class="card"
                style="padding: 1.5rem;"
                data-section-preview
                data-section-preview-fragment="biography-cards"
              >
                <div class="page-grid">
                  <div>
                    <h2 style="margin: 0;">Kartice</h2>
                    <p class="section-copy">
                      Naslov sekcije i dinamični profili tima. Svaki profil dobija svoju javnu
                      stranicu.
                    </p>
                  </div>

                  <div class="admin-form__grid">
                    <label class="admin-form__field admin-form__field--full">
                      <span>Naslov sekcije</span>
                      <input
                        class="input-control"
                        name="cardsTitle"
                        value={pageContent.cardsSection.title}
                      />
                    </label>

                    <div class="admin-form__field admin-form__field--full">
                      <span>Opis sekcije</span>
                      <AdminRichTextField
                        client:load
                        name="cardsCopy"
                        initialValue={pageContent.cardsSection.copy}
                        uploadUrl="/api/admin/media/upload"
                        uploadFolder="pages/biography"
                        labels={richTextLabels}
                      />
                    </div>

                    <div
                      class="admin-form__field admin-form__field--full"
                      data-biography-card-list
                      data-biography-card-rich-text-labels={JSON.stringify(richTextLabels)}
                    >
                      {pageContent.cardsSection.cards.map((card, index) => (
                        <div
                          class="admin-section-group admin-form__field--full"
                          data-biography-card-item
                        >
                          <div style="display: flex; justify-content: space-between; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
                            <h3 style="margin: 0;" data-biography-card-title>
                              Profil {index + 1}
                            </h3>
                            <button
                              class="button-secondary"
                              type="button"
                              data-biography-card-remove
                            >
                              Obriši profil
                            </button>
                          </div>

                          <div class="admin-form__grid">
                            <label class="admin-form__field">
                              <span>Slug</span>
                              <input
                                class="input-control"
                                data-biography-card-field="slug"
                                name={`biographyCard_${index}_slug`}
                                value={card.slug}
                              />
                            </label>

                            <label class="admin-form__field">
                              <span>Naslov</span>
                              <input
                                class="input-control"
                                data-biography-card-field="title"
                                name={`biographyCard_${index}_title`}
                                value={card.title}
                              />
                            </label>

                            <label class="admin-form__field">
                              <span>Rola</span>
                              <input
                                class="input-control"
                                data-biography-card-field="role"
                                name={`biographyCard_${index}_role`}
                                value={card.role}
                              />
                            </label>

                            <div class="admin-form__field admin-form__field--full">
                              <span>Sažetak na kartici</span>
                              <div
                                class="admin-biography-card-rich-text"
                                data-biography-card-field="summary"
                              >
                                <textarea data-biography-card-rtf-initial hidden>
                                  {card.summary}
                                </textarea>
                              </div>
                            </div>

                            <div class="admin-form__field admin-form__field--full">
                              <span>Detalj tekst stranice</span>
                              <div
                                class="admin-biography-card-rich-text"
                                data-biography-card-field="body"
                              >
                                <textarea data-biography-card-rtf-initial hidden>
                                  {card.body}
                                </textarea>
                              </div>
                            </div>

                            <div class="admin-inline-media-field admin-form__field--full">
                              <span>Slika</span>
                              <input
                                data-biography-card-field="image"
                                data-biography-card-image-input
                                name={`biographyCard_${index}_image`}
                                type="hidden"
                                value={card.image}
                              />
                              <div
                                class="admin-inline-media-field__preview"
                                data-biography-card-image-preview
                              >
                                {card.image ? (
                                  <img src={card.image} alt="" loading="lazy" />
                                ) : (
                                  <p class="admin-inline-media-field__empty">Slika nije dodata.</p>
                                )}
                              </div>
                              <div class="admin-inline-media-field__actions">
                                <label class="button-secondary admin-inline-media-field__upload">
                                  <span>Otpremi sliku</span>
                                  <input
                                    accept="image/*"
                                    data-biography-card-upload
                                    hidden
                                    type="file"
                                  />
                                </label>
                                <button
                                  class="button-secondary"
                                  data-biography-card-image-clear
                                  type="button"
                                >
                                  Ukloni sliku
                                </button>
                              </div>
                              <div
                                class="admin-upload-progress"
                                data-biography-card-image-progress
                                hidden
                              >
                                <div class="admin-upload-progress__track">
                                  <div
                                    class="admin-upload-progress__bar"
                                    data-biography-card-image-progress-bar
                                    style="width: 0%;"
                                  />
                                </div>
                              </div>
                              <p
                                class="admin-inline-media-field__status"
                                data-biography-card-image-status
                              />
                            </div>

                            {card.highlights.map((highlight, highlightIndex) => (
                              <label class="admin-form__field">
                                <span>Tag {highlightIndex + 1}</span>
                                <input
                                  class="input-control"
                                  data-biography-card-field={`highlight${highlightIndex + 1}`}
                                  name={`biographyCard_${index}_highlight${highlightIndex + 1}`}
                                  value={highlight}
                                />
                              </label>
                            ))}
                          </div>
                        </div>
                      ))}
                    </div>

                    <div class="admin-form__actions" style="justify-content: flex-start;">
                      <button class="button-secondary" type="button" data-biography-card-add>
                        Dodaj profil
                      </button>
                    </div>

                    <template data-biography-card-template>
                      <div
                        class="admin-section-group admin-form__field--full"
                        data-biography-card-item
                      >
                        <div style="display: flex; justify-content: space-between; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
                          <h3 style="margin: 0;" data-biography-card-title>
                            Profil
                          </h3>
                          <button class="button-secondary" type="button" data-biography-card-remove>
                            Obriši profil
                          </button>
                        </div>

                        <div class="admin-form__grid">
                          <label class="admin-form__field">
                            <span>Slug</span>
                            <input class="input-control" data-biography-card-field="slug" />
                          </label>

                          <label class="admin-form__field">
                            <span>Naslov</span>
                            <input class="input-control" data-biography-card-field="title" />
                          </label>

                          <label class="admin-form__field">
                            <span>Rola</span>
                            <input class="input-control" data-biography-card-field="role" />
                          </label>

                          <div class="admin-form__field admin-form__field--full">
                            <span>Sažetak na kartici</span>
                            <div
                              class="admin-biography-card-rich-text"
                              data-biography-card-field="summary"
                            >
                              <textarea data-biography-card-rtf-initial hidden />
                            </div>
                          </div>

                          <div class="admin-form__field admin-form__field--full">
                            <span>Detalj tekst stranice</span>
                            <div
                              class="admin-biography-card-rich-text"
                              data-biography-card-field="body"
                            >
                              <textarea data-biography-card-rtf-initial hidden />
                            </div>
                          </div>

                          <div class="admin-inline-media-field admin-form__field--full">
                            <span>Slika</span>
                            <input
                              data-biography-card-field="image"
                              data-biography-card-image-input
                              type="hidden"
                            />
                            <div
                              class="admin-inline-media-field__preview"
                              data-biography-card-image-preview
                            >
                              <p class="admin-inline-media-field__empty">Slika nije dodata.</p>
                            </div>
                            <div class="admin-inline-media-field__actions">
                              <label class="button-secondary admin-inline-media-field__upload">
                                <span>Otpremi sliku</span>
                                <input
                                  accept="image/*"
                                  data-biography-card-upload
                                  hidden
                                  type="file"
                                />
                              </label>
                              <button
                                class="button-secondary"
                                data-biography-card-image-clear
                                type="button"
                              >
                                Ukloni sliku
                              </button>
                            </div>
                            <div
                              class="admin-upload-progress"
                              data-biography-card-image-progress
                              hidden
                            >
                              <div class="admin-upload-progress__track">
                                <div
                                  class="admin-upload-progress__bar"
                                  data-biography-card-image-progress-bar
                                  style="width: 0%;"
                                />
                              </div>
                            </div>
                            <p
                              class="admin-inline-media-field__status"
                              data-biography-card-image-status
                            />
                          </div>

                          <label class="admin-form__field">
                            <span>Tag 1</span>
                            <input class="input-control" data-biography-card-field="highlight1" />
                          </label>

                          <label class="admin-form__field">
                            <span>Tag 2</span>
                            <input class="input-control" data-biography-card-field="highlight2" />
                          </label>

                          <label class="admin-form__field">
                            <span>Tag 3</span>
                            <input class="input-control" data-biography-card-field="highlight3" />
                          </label>
                        </div>
                      </div>
                    </template>
                  </div>
                </div>
              </div>

              <div
                class="card"
                style="padding: 1.5rem;"
                data-section-preview
                data-section-preview-fragment="biography-approach"
              >
                <div class="page-grid">
                  <div>
                    <h2 style="margin: 0;">Pristup radu</h2>
                    <p class="section-copy">Donja sekcija sa slikom i CTA dugmetom.</p>
                  </div>

                  <div class="admin-form__grid">
                    <label class="admin-form__field admin-form__field--full">
                      <span>Naslov</span>
                      <input
                        class="input-control"
                        name="approachTitle"
                        value={pageContent.approach.title}
                      />
                    </label>

                    <div class="admin-form__field admin-form__field--full">
                      <span>Opis</span>
                      <AdminRichTextField
                        client:load
                        name="approachCopy"
                        initialValue={pageContent.approach.copy}
                        uploadUrl="/api/admin/media/upload"
                        uploadFolder="pages/biography"
                        labels={richTextLabels}
                      />
                    </div>

                    {pageContent.approach.points.map((point, index) => (
                      <label class="admin-form__field">
                        <span>Stavka {index + 1}</span>
                        <input
                          class="input-control"
                          name={`approachPoint${index + 1}`}
                          value={point}
                        />
                      </label>
                    ))}

                    <AdminMediaField
                      client:load
                      name="approachImage"
                      label="Slika"
                      initialValue={pageContent.approach.image}
                      uploadUrl="/api/admin/media/upload"
                      uploadFolder="pages/biography"
                      uploadLabel="Otpremi sliku"
                    />

                    <label class="admin-form__field">
                      <span>Labela CTA dugmeta</span>
                      <input
                        class="input-control"
                        name="approachCtaLabel"
                        value={pageContent.approach.ctaLabel}
                      />
                    </label>
                  </div>
                </div>
              </div>
            </>
          );
        })()
      : null
  }

  {
    page === "psychotherapy"
      ? (() => {
          const pageContent = content as PsychotherapyPageManagedContent;

          return (
            <>
              <div
                class="card"
                style="padding: 1.5rem;"
                data-section-preview
                data-section-preview-fragment="psychotherapy-banner"
              >
                <div class="page-grid">
                  <div>
                    <h2 style="margin: 0;">Banner</h2>
                    <p class="section-copy">Naslovna sekcija stranice Pristup.</p>
                  </div>

                  <div class="admin-form__grid">
                    <label class="admin-form__field">
                      <span>Naslov</span>
                      <input
                        class="input-control"
                        name="bannerTitle"
                        value={pageContent.banner.title}
                      />
                    </label>

                    <div class="admin-form__field admin-form__field--full">
                      <span>Opis</span>
                      <AdminRichTextField
                        client:load
                        name="bannerDescription"
                        initialValue={pageContent.banner.description}
                        uploadUrl="/api/admin/media/upload"
                        uploadFolder="pages/psychotherapy"
                        labels={richTextLabels}
                      />
                    </div>

                    <AdminMediaField
                      client:load
                      name="bannerBackgroundImage"
                      label="Pozadinska slika"
                      initialValue={pageContent.banner.backgroundImage}
                      uploadUrl="/api/admin/media/upload"
                      uploadFolder="pages/psychotherapy"
                      uploadLabel="Otpremi sliku"
                    />
                  </div>
                </div>
              </div>

              <div
                class="card"
                style="padding: 1.5rem;"
                data-section-preview
                data-section-preview-fragment="psychotherapy-scope"
              >
                <div class="page-grid">
                  <div>
                    <h2 style="margin: 0;">Opseg rada</h2>
                    <p class="section-copy">Naslov i sedam stavki centralnog bloka.</p>
                  </div>

                  <div class="admin-form__grid">
                    <label class="admin-form__field admin-form__field--full">
                      <span>Naslov bloka</span>
                      <input
                        class="input-control"
                        name="scopeTitle"
                        value={pageContent.scope.title}
                      />
                    </label>

                    {pageContent.scope.items.map((item, index) => (
                      <label class="admin-form__field">
                        <span>Stavka {index + 1}</span>
                        <input class="input-control" name={`scopeItem${index + 1}`} value={item} />
                      </label>
                    ))}
