---
import { getDictionary } from "@/features/i18n/translate";
import { adminConfig } from "@/lib/config/admin";

type Props = {
  pathname: string;
};

const { pathname } = Astro.props;
const dictionary = getDictionary("sr-latn");
const normalizedPath = pathname.replace(/\/$/, "") || "/";
const normalizedBase = adminConfig.basePath.replace(/\/$/, "");

const isActive = (href: string) => {
  const normalizedHref = href.replace(/\/$/, "");

  if (normalizedHref === normalizedBase) {
    return normalizedPath === normalizedBase;
  }

  return normalizedPath.startsWith(normalizedHref);
};

const links = [
  { label: dictionary.admin.layout.pages, href: `${adminConfig.basePath}/pages/` },
  { label: dictionary.admin.layout.blog, href: `${adminConfig.basePath}/blog/` },
  { label: dictionary.admin.layout.submissions, href: `${adminConfig.basePath}/submissions/` },
];
---

<header class="admin-appbar appbar" data-initial-tone="light">
  <div class="container">
    <div class="admin-appbar__panel appbar__panel">
      <a class="admin-appbar__brand appbar__brand" href={`${adminConfig.basePath}/`}>
        {dictionary.admin.layout.title}
      </a>

      <nav class="admin-appbar__nav appbar__nav" aria-label={dictionary.a11y.appbarPrimaryNav}>
        {
          links.map((link) => (
            <a
              class:list={[
                "admin-appbar__link",
                "appbar__link",
                isActive(link.href) && "is-active",
              ]}
              href={link.href}
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <form class="admin-appbar__actions appbar__actions" action="/api/admin/logout" method="post">
        <button class="admin-appbar__logout appbar__cta" type="submit">
          {dictionary.admin.layout.logout}
        </button>
      </form>
    </div>
  </div>
</header>
