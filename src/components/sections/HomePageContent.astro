---
import AppointmentForm from "@/components/components/AppointmentForm.astro";
import type { HomePageData } from "@/data/fixtures/home";
import { localizePath } from "@/features/i18n/locale";
import { getDictionary } from "@/features/i18n/translate";
import type { BlogListItem } from "@/features/blog/types/blog.types";
import type { SiteLocale } from "@/lib/config/site";

type Props = {
  locale: SiteLocale;
  content: HomePageData;
  posts: BlogListItem[];
};

const { locale, content, posts } = Astro.props;
const dictionary = getDictionary(locale);
const youtubeShortCodeMatch = content.reasons.videoHref.match(/youtu\.be\/([^?&#]+)/);
const youtubeWatchMatch = content.reasons.videoHref.match(/[?&]v=([^&]+)/);
const youtubeVideoId = youtubeWatchMatch?.[1] ?? youtubeShortCodeMatch?.[1];
const vimeoMatch = content.reasons.videoHref.match(/vimeo\.com\/(?:video\/)?(\d+)/);
const isDirectVideo = /\.(mp4|webm|ogg|mov)(\?.*)?$/i.test(content.reasons.videoHref);
const homeVideoKind = isDirectVideo ? "direct" : "embed";
const homeVideoSrc = youtubeVideoId
  ? `https://www.youtube.com/embed/${youtubeVideoId}?autoplay=1&rel=0`
  : vimeoMatch?.[1]
    ? `https://player.vimeo.com/video/${vimeoMatch[1]}?autoplay=1`
    : content.reasons.videoHref;
---

<section id="home-prompt" class="home-section">
  <div class="container">
    <div class="home-heading-row home-heading-row--prompt">
      <div class="home-heading-copy home-heading-copy--prompt" data-reveal="up">
        <h2>{content.prompt.title}</h2>
        <div class="home-richtext" set:html={content.prompt.copy} />
      </div>
      <a
        class="home-button"
        href={content.prompt.href}
        data-reveal="up"
        style="--reveal-delay: 90ms;"
      >
        {content.prompt.label}
      </a>
    </div>
  </div>
</section>

<section id="home-about" class="home-section home-section--tight">
  <div class="container">
    <div class="home-about">
      <img
        class="home-about__image"
        src={content.about.image}
        alt={content.about.title}
        loading="lazy"
        data-image-component
        data-reveal="left"
      />
      <div class="home-about__content" data-reveal="right" style="--reveal-delay: 90ms;">
        <h2>{content.about.title}</h2>
        <div class="home-richtext" set:html={content.about.body} />
        <a class="home-button" href={content.about.href}>{content.about.label}</a>
      </div>
    </div>
  </div>
</section>

<section id="home-services" class="home-section home-section--dark">
  <div class="container">
    <div class="home-services">
      <div class="home-services__layout">
        <div class="home-services__intro" data-reveal="up">
          <h2 class="home-visually-hidden">{content.services.title}</h2>
          <div class="home-richtext home-richtext--light" set:html={content.services.copy} />
        </div>

        <div class="home-services__cards">
          {
            content.services.items.map((item, index) => (
              <a
                class="home-service-card"
                href={item.href ?? "#"}
                data-reveal="up"
                style={`--reveal-delay: ${90 + index * 90}ms;`}
              >
                <img
                  class="home-service-card__icon"
                  src={item.image}
                  alt=""
                  loading="lazy"
                  data-image-component
                  aria-hidden="true"
                />
                <div class="home-service-card__body">
                  <h3 class="home-service-title">{item.title}</h3>
                  <div
                    class="home-service-copy home-richtext home-richtext--light"
                    set:html={item.copy}
                  />
                  {
                    item.label ? (
                      <span class="home-inline-link home-inline-link--light home-inline-link--icon">
                        <span>{item.label}</span>
                        <svg
                          class="home-inline-link__icon"
                          aria-hidden="true"
                          viewBox="0 0 24 24"
                          fill="none"
                        >
                          <path
                            d="M7 17L17 7M9 7H17V15"
                            stroke="currentColor"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="1.9"
                          />
                        </svg>
                      </span>
                    ) : null
                  }
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<section id="home-themes" class="home-section">
  <div class="container">
    <div class="section-title-wrapper" data-reveal="up">
      <h2 class="heading-12">{content.themes.title}</h2>
    </div>

    <div class="collection-list-wrapper-w-100">
      <div role="list" class="collection-list-session-home-3">
        {
          content.themes.items.map((item, index) => (
            <div
              role="listitem"
              class="collection-item-session-home-3"
              data-reveal="up"
              style={`--reveal-delay: ${index * 90}ms;`}
            >
              <a href={item.href} class="link-block">
                <img
                  class="service-img"
                  src={item.image}
                  alt={item.title}
                  loading="lazy"
                  data-image-component
                />
              </a>
              <div class="info-collection-wrapper">
                <a href={item.href}>
                  <h3 class="service-name">{item.title}</h3>
                </a>
                <div class="mt-0 home-richtext" set:html={item.copy} />
                <div class="collection-link-wrapper">
                  <a class="link-with-icon" href={item.href}>
                    {item.label}
                    <svg
                      class="text-button-icon"
                      aria-hidden="true"
                      viewBox="0 0 24 24"
                      fill="none"
                    >
                      <path
                        d="M7 17L17 7M9 7H17V15"
                        stroke="currentColor"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.9"
                      />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<section id="home-reasons" class="home-section home-section--dark">
  <div class="container">
    <div class="home-reasons">
      <div class="home-reasons__intro" data-reveal="up">
        <h2>{content.reasons.title}</h2>
        <div class="home-richtext home-richtext--light" set:html={content.reasons.copy} />
      </div>

      <div class="home-reasons__grid">
        <div class="home-reason-list">
          {
            content.reasons.items.map((item, index) => (
              <article
                class="home-reason-panel"
                data-reveal="up"
                style={`--reveal-delay: ${index * 90}ms;`}
              >
                <span class="home-reason-panel__index">{String(index + 1).padStart(2, "0")}</span>
                <div class="home-reason-panel__content">
                  <div class="home-reason-panel__top">
                    <h3>{item.title}</h3>
                  </div>
                  <div class="home-richtext home-richtext--light" set:html={item.copy} />
                </div>
              </article>
            ))
          }
        </div>

        <button
          type="button"
          class="home-video-card"
          data-home-video-open
          data-video-kind={homeVideoKind}
          data-video-src={homeVideoSrc}
          aria-label={content.reasons.videoLabel}
          data-reveal="grow"
          style="--reveal-delay: 180ms;"
        >
          <img src={content.reasons.videoImage} alt="" loading="lazy" data-image-component />
          <span class="home-video-card__badge">{dictionary.common.play}</span>
          <span class="home-video-card__label">{content.reasons.videoLabel}</span>
        </button>
      </div>
    </div>
  </div>
</section>

<dialog class="home-video-dialog" data-home-video-dialog>
  <div class="home-video-dialog__surface">
    <button
      type="button"
      class="home-video-dialog__close"
      data-home-video-close
      aria-label={dictionary.common.close}
    >
      <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
        <path
          d="M6 6L18 18M18 6L6 18"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"></path>
      </svg>
    </button>
    <div class="home-video-dialog__frame">
      <iframe
        data-home-video-iframe
        title={content.reasons.videoLabel}
        allow="autoplay; fullscreen; picture-in-picture"></iframe>
      <video data-home-video-player controls playsinline hidden>
        <track kind="captions" />
      </video>
    </div>
  </div>
</dialog>

<script>
  (() => {
    const setupHomeVideo = () => {
      const dialog = document.querySelector("[data-home-video-dialog]");
      const openButton = document.querySelector("[data-home-video-open]");
      const closeButton = document.querySelector("[data-home-video-close]");
      const iframe = document.querySelector("[data-home-video-iframe]");
      const video = document.querySelector("[data-home-video-player]");

      if (
        !(openButton instanceof HTMLElement) ||
        !(closeButton instanceof HTMLElement) ||
        !(dialog instanceof HTMLElement) ||
        !(iframe instanceof HTMLElement) ||
        !(video instanceof HTMLElement) ||
        dialog.dataset.bound === "true"
      ) {
        return;
      }

      const supportsDialog =
        typeof HTMLDialogElement !== "undefined" &&
        dialog instanceof HTMLDialogElement &&
        typeof dialog.showModal === "function";

      const closeDialog = () => {
        if (supportsDialog) {
          dialog.close();
        }
      };

      openButton.addEventListener("click", () => {
        const src = openButton.dataset.videoSrc;
        if (!src) {
          return;
        }

        if (!supportsDialog) {
          window.open(src, "_blank", "noopener");
          return;
        }

        if (openButton.dataset.videoKind === "direct") {
          iframe.hidden = true;
          iframe.src = "";
          video.hidden = false;
          video.src = src;
          void video.play().catch(() => {});
        } else {
          video.hidden = true;
          video.pause();
          video.removeAttribute("src");
          video.load();
          iframe.hidden = false;
          iframe.src = src;
        }

        dialog.showModal();
      });

      closeButton.addEventListener("click", closeDialog);

      dialog.addEventListener("click", (event) => {
        if (event.target === dialog) {
          closeDialog();
        }
      });

      dialog.addEventListener("close", () => {
        iframe.src = "";
        video.pause();
        video.removeAttribute("src");
        video.load();
      });

      dialog.dataset.bound = "true";
    };

    setupHomeVideo();
  })();
</script>

<section id="home-booking" class="home-section home-section--tight">
  <div class="container">
    <div class="home-booking">
      <div class="home-booking__intro" data-reveal="up">
        <h2>{content.booking.title}</h2>
        <div class="home-richtext" set:html={content.booking.copy} />
      </div>

      <div data-reveal="up" style="--reveal-delay: 90ms;">
        <AppointmentForm
          locale={locale}
          labels={dictionary.forms}
          formatLabel={content.booking.formatLabel}
          formats={content.booking.formats}
        />
      </div>
    </div>
  </div>
</section>

<section id="home-blog" class="home-section">
  <div class="container">
    <div class="home-heading-row home-heading-row--blog">
      <div class="home-heading-copy" data-reveal="up">
        <h2>{content.recent.title}</h2>
        <div class="home-richtext" set:html={content.recent.copy} />
      </div>
      <a
        class="home-button"
        href={content.recent.href}
        data-reveal="up"
        style="--reveal-delay: 90ms;"
      >
        {content.recent.label}
      </a>
    </div>

    {
      posts.length > 0 ? (
        <div class="home-card-grid home-card-grid--blog">
          {posts.map((post, index) => (
            <article
              class="home-blog-card"
              data-reveal="up"
              style={`--reveal-delay: ${index * 90}ms;`}
            >
              <a class="home-blog-card__media" href={localizePath(locale, `/blog/${post.slug}/`)}>
                <img
                  src={post.coverImage ?? "/legacy/images/Blog-1_1Blog 1.webp"}
                  alt={post.title}
                  loading="lazy"
                  data-image-component
                />
              </a>
              <div class="home-blog-card__body">
                <div class="home-post-meta">
                  <span>
                    {post.publishedAt.toLocaleDateString(
                      locale === "sr-cyrl" ? "sr-Cyrl-RS" : "sr-RS",
                    )}
                  </span>
                  <span>&bull;</span>
                  <span>{post.tags.join(", ") || dictionary.blog.defaultTag}</span>
                </div>
                <div class="home-blog-card__copy">
                  <h3>{post.title}</h3>
                  <div class="home-blog-card__excerpt" set:html={post.excerpt} />
                </div>
                <a
                  class="home-blog-card__action"
                  href={localizePath(locale, `/blog/${post.slug}/`)}
                >
                  <span>{dictionary.blog.readMoreLabel}</span>
                  <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
                    <path
                      d="M7 17L17 7M9 7H17V15"
                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.9"
                    />
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="home-card" data-reveal="up">
          <p>{content.recent.empty}</p>
        </div>
      )
    }
  </div>
</section>
