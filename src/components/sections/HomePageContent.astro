---
import { AppointmentForm } from "@/components/components/AppointmentForm";
import { getHomePageData } from "@/data/fixtures/home";
import { localizePath } from "@/features/i18n/locale";
import { getDictionary } from "@/features/i18n/translate";
import type { BlogListItem } from "@/features/blog/types/blog.types";
import type { SiteLocale } from "@/lib/config/site";

type Props = {
  locale: SiteLocale;
  posts: BlogListItem[];
};

const { locale, posts } = Astro.props;
const dictionary = getDictionary(locale);
const content = getHomePageData(locale);
const videoIdMatch = content.reasons.videoHref.match(/[?&]v=([^&]+)/);
const homeVideoEmbedSrc = videoIdMatch
  ? `https://www.youtube.com/embed/${videoIdMatch[1]}?autoplay=1&rel=0`
  : content.reasons.videoHref;
---

<section class="home-section">
  <div class="container">
    <div class="home-heading-row home-heading-row--prompt">
      <div class="home-heading-copy home-heading-copy--prompt">
        <h2>{content.prompt.title}</h2>
        <p>{content.prompt.copy}</p>
      </div>
      <a class="home-button" href={content.prompt.href}>{content.prompt.label}</a>
    </div>
  </div>
</section>

<section class="home-section home-section--tight">
  <div class="container">
    <div class="home-about">
      <img
        class="home-about__image"
        src={content.about.image}
        alt={content.about.title}
        loading="lazy"
      />
      <div class="home-about__content">
        <h2>{content.about.title}</h2>
        {content.about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        <ul class="home-list">
          {content.about.bullets.map((bullet) => <li>{bullet}</li>)}
        </ul>
        <a class="home-button" href={content.about.href}>{content.about.label}</a>
      </div>
    </div>
  </div>
</section>

<section class="home-section home-section--dark">
  <div class="container">
    <div class="home-services">
      <div class="home-services__layout">
        <div class="home-services__intro">
          <h2>{content.services.title}</h2>
          <p>{content.services.copy}</p>
        </div>

        <div class="home-services__cards">
          {
            content.services.items.map((item) => (
              <article class="home-service-card">
                <img
                  class="home-service-card__icon"
                  src={item.image}
                  alt=""
                  loading="lazy"
                  aria-hidden="true"
                />
                <div class="home-service-card__body">
                  <h3 class="home-service-title">{item.title}</h3>
                  <p class="home-service-copy">{item.copy}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<section class="home-section">
  <div class="container">
    <div class="section-title-wrapper">
      <h2 class="heading-12">{content.themes.title}</h2>
    </div>

    <div class="collection-list-wrapper-w-100">
      <div role="list" class="collection-list-session-home-3">
        {
          content.themes.items.map((item) => (
            <div role="listitem" class="collection-item-session-home-3">
              <a href={item.href} class="link-block">
                <img class="service-img" src={item.image} alt={item.title} loading="lazy" />
              </a>
              <div class="info-collection-wrapper">
                <a href={item.href}>
                  <h5 class="service-name">{item.title}</h5>
                </a>
                <p class="mt-0">{item.copy}</p>
                <div class="collection-link-wrapper">
                  <a class="link-with-icon" href={item.href}>
                    {item.label}
                    <svg class="text-button-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none">
                      <path
                        d="M7 17L17 7M9 7H17V15"
                        stroke="currentColor"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.9"></path>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<section class="home-section home-section--dark">
  <div class="container">
    <div class="home-reasons">
      <div class="home-reasons__intro">
        <h2>{content.reasons.title}</h2>
        <p>{content.reasons.copy}</p>
      </div>

      <div class="home-reasons__grid">
        <div class="home-reason-list">
          {
            content.reasons.items.map((item, index) => (
              <a class="home-reason-panel" href={item.href}>
                <span class="home-reason-panel__index">{String(index + 1).padStart(2, "0")}</span>
                <div class="home-reason-panel__content">
                  <div class="home-reason-panel__top">
                    <h3>{item.title}</h3>
                    <span class="home-inline-link home-inline-link--light home-inline-link--icon">
                      <span>{item.label}</span>
                      <svg
                        class="home-inline-link__icon"
                        aria-hidden="true"
                        viewBox="0 0 24 24"
                        fill="none">
                        <path
                          d="M7 17L17 7M9 7H17V15"
                          stroke="currentColor"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="1.9"></path>
                      </svg>
                    </span>
                  </div>
                  <p>{item.copy}</p>
                </div>
              </a>
            ))
          }
        </div>

        <button
          type="button"
          class="home-video-card"
          data-home-video-open
          data-video-src={homeVideoEmbedSrc}
          aria-label={content.reasons.videoLabel}
        >
          <img src={content.reasons.videoImage} alt="" loading="lazy" />
          <span class="home-video-card__badge">{dictionary.common.play}</span>
          <span class="home-video-card__label">{content.reasons.videoLabel}</span>
        </button>
      </div>
    </div>
  </div>
</section>

<dialog class="home-video-dialog" data-home-video-dialog>
  <div class="home-video-dialog__surface">
    <button
      type="button"
      class="home-video-dialog__close"
      data-home-video-close
      aria-label={dictionary.common.close}>
      <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
        <path
          d="M6 6L18 18M18 6L6 18"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"></path>
      </svg>
    </button>
    <div class="home-video-dialog__frame">
      <iframe
        data-home-video-iframe
        title={content.reasons.videoLabel}
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen></iframe>
    </div>
  </div>
</dialog>

<script is:inline>
  (() => {
    const setupHomeVideo = () => {
      const dialog = document.querySelector("[data-home-video-dialog]");
      const openButton = document.querySelector("[data-home-video-open]");
      const closeButton = document.querySelector("[data-home-video-close]");
      const iframe = document.querySelector("[data-home-video-iframe]");

      if (
        !(dialog instanceof HTMLDialogElement) ||
        !(openButton instanceof HTMLElement) ||
        !(closeButton instanceof HTMLElement) ||
        !(iframe instanceof HTMLIFrameElement) ||
        dialog.dataset.bound === "true"
      ) {
        return;
      }

      const closeDialog = () => {
        dialog.close();
      };

      openButton.addEventListener("click", () => {
        const src = openButton.dataset.videoSrc;
        if (!src) {
          return;
        }

        iframe.src = src;
        dialog.showModal();
      });

      closeButton.addEventListener("click", closeDialog);

      dialog.addEventListener("click", (event) => {
        if (event.target === dialog) {
          closeDialog();
        }
      });

      dialog.addEventListener("close", () => {
        iframe.src = "";
      });

      dialog.dataset.bound = "true";
    };

    setupHomeVideo();
    document.addEventListener("astro:page-load", setupHomeVideo);
  })();
</script>

<section class="home-section home-section--tight">
  <div class="container">
    <div class="home-booking">
      <div class="home-booking__intro">
        <h2>{content.booking.title}</h2>
        <p>{content.booking.copy}</p>
        <div class="home-booking__formats">
          {content.booking.formats.map((format) => <span class="home-pill">{format}</span>)}
        </div>
      </div>

      <AppointmentForm
        client:load
        locale={locale}
        labels={dictionary.forms}
        formatLabel={content.booking.formatLabel}
        formats={content.booking.formats}
      />
    </div>
  </div>
</section>

<section class="home-section">
  <div class="container">
    <div class="home-heading-row home-heading-row--blog">
      <div class="home-heading-copy">
        <h2>{content.recent.title}</h2>
        <p>{content.recent.copy}</p>
      </div>
      <a class="home-button" href={content.recent.href}>{content.recent.label}</a>
    </div>

    {
      posts.length > 0 ? (
        <div class="home-card-grid home-card-grid--blog">
          {posts.map((post) => (
            <article class="home-blog-card">
              <a class="home-blog-card__media" href={localizePath(locale, `/blog/${post.slug}/`)}>
                <img
                  src={post.coverImage ?? "/legacy/images/Blog-1_1Blog 1.webp"}
                  alt={post.title}
                  loading="lazy"
                />
              </a>
              <div class="home-blog-card__body">
                <div class="home-post-meta">
                  <span>
                    {post.publishedAt.toLocaleDateString(
                      locale === "sr-cyrl" ? "sr-Cyrl-RS" : "sr-RS",
                    )}
                  </span>
                  <span>&bull;</span>
                  <span>{post.tags.join(", ") || dictionary.blog.defaultTag}</span>
                </div>
                <div class="home-blog-card__copy">
                  <h3>{post.title}</h3>
                  <p>{post.excerpt}</p>
                </div>
                <a
                  class="home-blog-card__action"
                  href={localizePath(locale, `/blog/${post.slug}/`)}
                >
                  <span>{dictionary.blog.readMoreLabel}</span>
                  <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
                    <path
                      d="M7 17L17 7M9 7H17V15"
                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.9"></path>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="home-card">
          <p>{content.recent.empty}</p>
        </div>
      )
    }
  </div>
</section>
