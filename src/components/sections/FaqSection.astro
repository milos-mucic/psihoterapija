---
import type { FaqItem } from "@/data/fixtures/faq";

type Props = {
  title: string;
  items: FaqItem[];
};

const { title, items } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="page-grid">
      <h2 class="section-title" style="font-size: clamp(1.8rem, 3.5vw, 3rem);">{title}</h2>
      <div class="page-grid">
        {items.map((item) => (
          <article class="card" style="padding: 1.4rem;">
            <h3 style="margin-top: 0;">{item.question}</h3>
            <p style="margin: 0; color: var(--muted);">{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
