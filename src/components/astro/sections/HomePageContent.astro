---
import { AppointmentForm } from "@/components/react/forms/AppointmentForm";
import { getHomePageData } from "@/data/fixtures/home";
import { localizePath } from "@/features/i18n/locale";
import { getDictionary } from "@/features/i18n/translate";
import type { BlogListItem } from "@/features/blog/types/blog.types";
import type { SiteLocale } from "@/lib/config/site";

type Props = {
  locale: SiteLocale;
  posts: BlogListItem[];
};

const { locale, posts } = Astro.props;
const dictionary = getDictionary(locale);
const content = getHomePageData(locale);
---

<section class="home-section">
  <div class="container">
    <div class="home-heading-row">
      <div class="home-heading-copy">
        <h2>{content.prompt.title}</h2>
        <p>{content.prompt.copy}</p>
      </div>
      <a class="home-button" href={content.prompt.href}>{content.prompt.label}</a>
    </div>
  </div>
</section>

<section class="home-section home-section--tight">
  <div class="container">
    <div class="home-about">
      <img class="home-about__image" src={content.about.image} alt={content.about.title} loading="lazy" />
      <div class="home-about__content">
        <h2>{content.about.title}</h2>
        {content.about.paragraphs.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
        <ul class="home-list">
          {content.about.bullets.map((bullet) => (
            <li>{bullet}</li>
          ))}
        </ul>
        <a class="home-button" href={content.about.href}>{content.about.label}</a>
      </div>
    </div>
  </div>
</section>

<section class="home-section home-section--dark">
  <div class="container">
    <div class="home-services">
      <div class="home-services__intro">
        <h2>{content.services.title}</h2>
        <p>{content.services.copy}</p>
      </div>

      <div class="home-services__grid">
        {content.services.items.map((item) => (
          <article class="home-dark-card">
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
            <a class="home-inline-link home-inline-link--light" href={item.href}>
              {item.label}
            </a>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<section class="home-section home-section--tight">
  <div class="container">
    <div class="home-promo">
      <div class="home-promo__content">
        <h2>{content.promo.title}</h2>
        <a class="home-inline-link" href={content.promo.href}>
          {content.promo.label}
        </a>
      </div>
      <img class="home-promo__image" src={content.promo.image} alt="" loading="lazy" />
    </div>
  </div>
</section>

<section class="home-section">
  <div class="container">
    <div class="home-center-heading">
      <h2>{content.themes.title}</h2>
    </div>

    <div class="home-card-grid">
      {content.themes.items.map((item) => (
        <article class="home-card">
          <h3>{item.title}</h3>
          <p>{item.copy}</p>
          <a class="home-inline-link" href={item.href}>
            {item.label}
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="home-section home-section--dark">
  <div class="container">
    <div class="home-reasons">
      <div class="home-reasons__intro">
        <h2>{content.reasons.title}</h2>
        <p>{content.reasons.copy}</p>
      </div>

      <div class="home-reasons__grid">
        <div class="home-reasons__cards">
          {content.reasons.items.map((item) => (
            <article class="home-dark-card">
              <h3>{item.title}</h3>
              <p>{item.copy}</p>
              <a class="home-inline-link home-inline-link--light" href={item.href}>
                {item.label}
              </a>
            </article>
          ))}
        </div>

        <a class="home-video-card" href={content.reasons.videoHref} target="_blank" rel="noreferrer">
          <img src={content.reasons.videoImage} alt="" loading="lazy" />
          <span class="home-video-card__badge">{dictionary.common.play}</span>
          <span class="home-video-card__label">{content.reasons.videoLabel}</span>
        </a>
      </div>
    </div>
  </div>
</section>

<section class="home-section home-section--tight">
  <div class="container">
    <div class="home-booking">
      <div class="home-booking__intro">
        <h2>{content.booking.title}</h2>
        <p>{content.booking.copy}</p>
        <div class="home-booking__formats">
          {content.booking.formats.map((format) => (
            <span class="home-pill">{format}</span>
          ))}
        </div>
      </div>

      <AppointmentForm
        client:load
        locale={locale}
        labels={dictionary.forms}
        formatLabel={content.booking.formatLabel}
        formats={content.booking.formats}
      />
    </div>
  </div>
</section>

<section class="home-section">
  <div class="container">
    <div class="home-heading-row">
      <div class="home-heading-copy">
        <h2>{content.recent.title}</h2>
        <p>{content.recent.copy}</p>
      </div>
      <a class="home-button" href={content.recent.href}>{content.recent.label}</a>
    </div>

    {
      posts.length > 0 ? (
        <div class="home-card-grid">
          {posts.map((post) => (
            <article class="home-card">
              <div class="home-post-meta">
                <span>{post.publishedAt.toLocaleDateString(locale === "sr-cyrl" ? "sr-Cyrl-RS" : "sr-RS")}</span>
                <span>&bull;</span>
                <span>{post.tags.join(", ") || dictionary.blog.defaultTag}</span>
              </div>
              <h3>{post.title}</h3>
              <p>{post.excerpt}</p>
              <a class="home-inline-link" href={localizePath(locale, `/blog/${post.slug}/`)}>
                {dictionary.blog.readMoreLabel}
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="home-card">
          <p>{content.recent.empty}</p>
        </div>
      )
    }
  </div>
</section>
