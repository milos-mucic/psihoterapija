---
export const prerender = true;

import PsychotherapyPage from "@/components/astro/pages/PsychotherapyPage.astro";
import { getPsychotherapyPageData } from "@/data/fixtures/public-pages";
import BaseLayout from "@/layouts/BaseLayout.astro";

const locale = "sr-cyrl";
const content = getPsychotherapyPageData(locale);
---

<BaseLayout
  title="Психотерапија | Психотерапијски кабинет Икар"
  description={content.banner.description ?? "Психотерапијски приступ и опсег рада кабинета Икар."}
  locale={locale}
  canonicalPath="/cir/psihoterapija/"
>
  <PsychotherapyPage locale={locale} />
</BaseLayout>
