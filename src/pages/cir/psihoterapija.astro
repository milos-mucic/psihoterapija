---
export const prerender = true;

import PsychotherapyPage from "@/components/pages/PsychotherapyPage.astro";
import { getDictionary } from "@/features/i18n/translate";
import { pageContentService } from "@/features/page-content/services/page-content.service";
import BaseLayout from "@/components/components/BaseLayout.astro";

const locale = "sr-cyrl";
const dictionary = getDictionary(locale);
const content = await pageContentService.getPsychotherapyPageData(locale);
---

<BaseLayout
  title={dictionary.meta.psychotherapy.title}
  description={content.banner.description || dictionary.meta.psychotherapy.description}
  locale={locale}
  canonicalPath="/cir/psihoterapija/"
>
  <PsychotherapyPage locale={locale} />
</BaseLayout>
