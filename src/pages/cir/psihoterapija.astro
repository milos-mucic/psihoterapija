---
export const prerender = true;

import PsychotherapyPage from "@/components/astro/pages/PsychotherapyPage.astro";
import { getDictionary } from "@/features/i18n/translate";
import BaseLayout from "@/layouts/BaseLayout.astro";

const locale = "sr-cyrl";
const dictionary = getDictionary(locale);
---

<BaseLayout
  title={dictionary.meta.psychotherapy.title}
  description={dictionary.meta.psychotherapy.description}
  locale={locale}
  canonicalPath="/cir/psihoterapija/"
>
  <PsychotherapyPage locale={locale} />
</BaseLayout>
