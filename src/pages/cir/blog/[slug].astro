---
export const prerender = false;

import { blogService } from "@/features/blog/services/blog.service";
import BlogPostLayout from "@/components/components/BlogPostLayout.astro";

const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing blog slug.");
}

const post = await blogService.getPostBySlug("sr-cyrl", slug);

if (!post || post.status !== "published") {
  return Astro.redirect("/cir/blog/");
}
---

<BlogPostLayout
  title={post.title}
  description={post.seoDescription ?? post.excerpt}
  locale="sr-cyrl"
  canonicalPath={`/cir/blog/${post.slug}/`}
  publishedAt={post.publishedAt}
>
  <div set:html={post.body} />
</BlogPostLayout>
