---
import BaseLayout from "@/components/components/BaseLayout.astro";
import ScopeDetailPage from "@/components/pages/ScopeDetailPage.astro";
import { getDictionary } from "@/features/i18n/translate";
import { pageContentService } from "@/features/page-content/services/page-content.service";
import { siteConfig } from "@/lib/config/site";

const locale = "sr-cyrl";
const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing scope detail slug.");
}

const content = await pageContentService.getScopeDetailPageData(locale, slug);
const dictionary = getDictionary(locale);

if (!content) {
  return Astro.redirect("/cir/oblast-rada/");
}
---

<BaseLayout
  title={`${content.banner.title} | ${siteConfig.name}`}
  description={content.banner.description ?? dictionary.meta.psychotherapy.description}
  locale={locale}
  canonicalPath={`/cir/oblast-rada/${slug}/`}
>
  <ScopeDetailPage locale={locale} slug={slug} />
</BaseLayout>
