---
export const prerender = true;

import AppointmentPage from "@/components/astro/pages/AppointmentPage.astro";
import { getAppointmentPageData } from "@/data/fixtures/public-pages";
import BaseLayout from "@/layouts/BaseLayout.astro";

const locale = "sr-cyrl";
const content = getAppointmentPageData(locale);
---

<BaseLayout
  title="Заказивање | Психотерапијски кабинет Икар"
  description={content.banner.description ?? "Закажите термин у Психотерапијском кабинету Икар."}
  locale={locale}
  canonicalPath="/cir/zakazivanje/"
>
  <AppointmentPage locale={locale} />
</BaseLayout>
