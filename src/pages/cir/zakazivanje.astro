---
export const prerender = true;

import AppointmentPage from "@/components/astro/pages/AppointmentPage.astro";
import { getDictionary } from "@/features/i18n/translate";
import BaseLayout from "@/layouts/BaseLayout.astro";

const locale = "sr-cyrl";
const dictionary = getDictionary(locale);
---

<BaseLayout
  title={dictionary.meta.appointment.title}
  description={dictionary.meta.appointment.description}
  locale={locale}
  canonicalPath="/cir/zakazivanje/"
>
  <AppointmentPage locale={locale} />
</BaseLayout>
