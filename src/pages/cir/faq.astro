---
export const prerender = true;

import FaqPage from "@/components/astro/pages/FaqPage.astro";
import { getDictionary } from "@/features/i18n/translate";
import BaseLayout from "@/layouts/BaseLayout.astro";

const locale = "sr-cyrl";
const dictionary = getDictionary(locale);
---

<BaseLayout
  title={dictionary.meta.faq.title}
  description={dictionary.meta.faq.description}
  locale={locale}
  canonicalPath="/cir/faq/"
>
  <FaqPage locale={locale} />
</BaseLayout>
