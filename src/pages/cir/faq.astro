---
export const prerender = true;

import FaqPage from "@/components/astro/pages/FaqPage.astro";
import { getFaqPageData } from "@/data/fixtures/public-pages";
import BaseLayout from "@/layouts/BaseLayout.astro";

const locale = "sr-cyrl";
const content = getFaqPageData(locale);
---

<BaseLayout
  title="Честа питања | Психотерапијски кабинет Икар"
  description={content.banner.description ?? "Најчешћа питања о психотерапији и раду кабинета Икар."}
  locale={locale}
  canonicalPath="/cir/faq/"
>
  <FaqPage locale={locale} />
</BaseLayout>
