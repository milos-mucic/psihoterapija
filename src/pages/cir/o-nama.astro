---
export const prerender = true;

import AboutPage from "@/components/astro/pages/AboutPage.astro";
import { getAboutPageData } from "@/data/fixtures/public-pages";
import BaseLayout from "@/layouts/BaseLayout.astro";

const locale = "sr-cyrl";
const content = getAboutPageData(locale);
---

<BaseLayout
  title="О нама | Психотерапијски кабинет Икар"
  description={content.banner.description ?? "Сазнајте више о Психотерапијском кабинету Икар."}
  locale={locale}
  canonicalPath="/cir/o-nama/"
>
  <AboutPage locale={locale} />
</BaseLayout>
