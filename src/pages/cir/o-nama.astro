---
export const prerender = true;

import AboutPage from "@/components/pages/AboutPage.astro";
import { getDictionary } from "@/features/i18n/translate";
import BaseLayout from "@/components/components/BaseLayout.astro";

const locale = "sr-cyrl";
const dictionary = getDictionary(locale);
---

<BaseLayout
  title={dictionary.meta.about.title}
  description={dictionary.meta.about.description}
  locale={locale}
  canonicalPath="/cir/o-nama/"
>
  <AboutPage locale={locale} />
</BaseLayout>
