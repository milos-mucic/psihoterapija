---
export const prerender = true;

import ContactPage from "@/components/astro/pages/ContactPage.astro";
import { getDictionary } from "@/features/i18n/translate";
import BaseLayout from "@/layouts/BaseLayout.astro";

const locale = "sr-cyrl";
const dictionary = getDictionary(locale);
---

<BaseLayout
  title={dictionary.meta.contact.title}
  description={dictionary.meta.contact.description}
  locale={locale}
  canonicalPath="/cir/kontakt/"
>
  <ContactPage locale={locale} />
</BaseLayout>
