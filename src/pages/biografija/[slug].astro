---
import BaseLayout from "@/components/components/BaseLayout.astro";
import BiographyProfilePage from "@/components/pages/BiographyProfilePage.astro";
import { pageContentService } from "@/features/page-content/services/page-content.service";
import { siteConfig } from "@/lib/config/site";

const locale = "sr-latn";
const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing biography profile slug.");
}

const content = await pageContentService.getBiographyProfilePageData(locale, slug);

if (!content) {
  return Astro.redirect("/biografija/");
}
---

<BaseLayout
  title={`${content.profile.title} | ${siteConfig.name}`}
  description={content.profile.summary}
  locale={locale}
  canonicalPath={`/biografija/${slug}/`}
  appBarTone="dark"
  appBarOverlay={true}
>
  <BiographyProfilePage locale={locale} slug={slug} />
</BaseLayout>
