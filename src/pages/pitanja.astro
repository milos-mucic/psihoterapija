---
export const prerender = true;

import FaqPage from "@/components/pages/FaqPage.astro";
import { pageContentService } from "@/features/page-content/services/page-content.service";
import BaseLayout from "@/components/components/BaseLayout.astro";

const locale = "sr-latn";
const content = await pageContentService.getFaqPageData(locale);
---

<BaseLayout
  title={content.seo.title}
  description={content.seo.description}
  locale={locale}
  canonicalPath="/pitanja/"
  appBarTone="dark"
  appBarOverlay={true}
>
  <FaqPage locale={locale} />
</BaseLayout>
