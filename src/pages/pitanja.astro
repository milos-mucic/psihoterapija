---
export const prerender = true;

import FaqPage from "@/components/pages/FaqPage.astro";
import { getDictionary } from "@/features/i18n/translate";
import BaseLayout from "@/components/components/BaseLayout.astro";

const locale = "sr-latn";
const dictionary = getDictionary(locale);
---

<BaseLayout
  title={dictionary.meta.faq.title}
  description={dictionary.meta.faq.description}
  locale={locale}
  canonicalPath="/pitanja/"
  appBarTone="dark"
  appBarOverlay={true}
>
  <FaqPage locale={locale} />
</BaseLayout>
