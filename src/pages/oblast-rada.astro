---
export const prerender = true;

import BaseLayout from "@/components/components/BaseLayout.astro";
import ScopePage from "@/components/pages/ScopePage.astro";
import { pageContentService } from "@/features/page-content/services/page-content.service";

const locale = "sr-latn";
const content = await pageContentService.getScopePageData(locale);
---

<BaseLayout
  title={content.seo.title}
  description={content.seo.description}
  locale={locale}
  canonicalPath="/oblast-rada/"
>
  <ScopePage locale={locale} />
</BaseLayout>
