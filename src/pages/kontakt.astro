---
export const prerender = true;

import ContactPage from "@/components/pages/ContactPage.astro";
import { pageContentService } from "@/features/page-content/services/page-content.service";
import BaseLayout from "@/components/components/BaseLayout.astro";

const locale = "sr-latn";
const content = await pageContentService.getContactPageData(locale);
---

<BaseLayout
  title={content.seo.title}
  description={content.seo.description}
  locale={locale}
  canonicalPath="/kontakt/"
>
  <ContactPage locale={locale} content={content} />
</BaseLayout>
