---
export const prerender = true;

import ContactPage from "@/components/astro/pages/ContactPage.astro";
import { getContactPageData } from "@/data/fixtures/public-pages";
import BaseLayout from "@/layouts/BaseLayout.astro";

const locale = "sr-latn";
const content = getContactPageData(locale);
---

<BaseLayout
  title="Kontakt | Psihoterapijski kabinet Ikar"
  description={content.introCopy}
  locale={locale}
  canonicalPath="/kontakt/"
>
  <ContactPage locale={locale} />
</BaseLayout>
