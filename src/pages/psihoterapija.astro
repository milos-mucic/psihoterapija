---
export const prerender = true;

import PsychotherapyPage from "@/components/astro/pages/PsychotherapyPage.astro";
import { getPsychotherapyPageData } from "@/data/fixtures/public-pages";
import BaseLayout from "@/layouts/BaseLayout.astro";

const locale = "sr-latn";
const content = getPsychotherapyPageData(locale);
---

<BaseLayout
  title="Psihoterapija | Psihoterapijski kabinet Ikar"
  description={content.banner.description ?? "Psihoterapijski pristup i opseg rada kabineta Ikar."}
  locale={locale}
  canonicalPath="/psihoterapija/"
>
  <PsychotherapyPage locale={locale} />
</BaseLayout>
