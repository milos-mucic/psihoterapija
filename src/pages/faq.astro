---
export const prerender = true;

import FaqPage from "@/components/astro/pages/FaqPage.astro";
import { getFaqPageData } from "@/data/fixtures/public-pages";
import BaseLayout from "@/layouts/BaseLayout.astro";

const locale = "sr-latn";
const content = getFaqPageData(locale);
---

<BaseLayout
  title="FAQ | Psihoterapijski kabinet Ikar"
  description={content.banner.description ?? "Najcesca pitanja o psihoterapiji i radu kabineta Ikar."}
  locale={locale}
  canonicalPath="/faq/"
>
  <FaqPage locale={locale} />
</BaseLayout>
