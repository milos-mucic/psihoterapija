---
import { getDictionary } from "@/features/i18n/translate";
import { submissionService } from "@/features/forms/services/submission.service";
import { adminConfig } from "@/lib/config/admin";
import AdminLayout from "@/components/components/AdminLayout.astro";

const dictionary = getDictionary("sr-latn");
const submissions = await submissionService.listSubmissions();
---

<AdminLayout title={dictionary.meta.admin.submissionsTitle}>
  <div class="admin-grid">
    <div class="card" style="padding: 1.5rem;">
      <h2 style="margin: 0;">{dictionary.admin.submissions.title}</h2>
      <p style="margin: 0.5rem 0 0; color: var(--muted);">{dictionary.admin.submissions.copy}</p>
    </div>

    <div class="card" style="padding: 1.2rem;">
      <table class="admin-table">
        <thead>
          <tr>
            <th>{dictionary.admin.submissions.headers.type}</th>
            <th>{dictionary.admin.submissions.headers.name}</th>
            <th>{dictionary.admin.submissions.headers.email}</th>
            <th>{dictionary.admin.submissions.headers.status}</th>
            <th>{dictionary.admin.submissions.headers.date}</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {submissions.length === 0 ? (
            <tr>
              <td colspan="6">{dictionary.admin.submissions.empty}</td>
            </tr>
          ) : (
            submissions.map((submission) => (
              <tr>
                <td>{submission.type}</td>
                <td>{submission.name}</td>
                <td>{submission.email}</td>
                <td>{submission.status}</td>
                <td>{new Date(submission.createdAt).toLocaleString("sr-RS")}</td>
                <td>
                  <a href={`${adminConfig.basePath}/submissions/${submission.id}/`}>
                    {dictionary.admin.submissions.headers.details}
                  </a>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
