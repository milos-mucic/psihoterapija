---
import { submissionService } from "@/features/forms/services/submission.service";
import { adminConfig } from "@/lib/config/admin";
import AdminLayout from "@/layouts/AdminLayout.astro";

const submissions = await submissionService.listSubmissions();
---

<AdminLayout title="Submissions | Ikar admin">
  <div class="admin-grid">
    <div class="card" style="padding: 1.5rem;">
      <h2 style="margin: 0;">Prijave i poruke</h2>
      <p style="margin: 0.5rem 0 0; color: var(--muted);">Ove stavke trenutno dolaze iz lokalnog JSON repozitorijuma i spremne su za kasniju migraciju na bazu.</p>
    </div>

    <div class="card" style="padding: 1.2rem;">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Tip</th>
            <th>Ime</th>
            <th>Email</th>
            <th>Status</th>
            <th>Datum</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {submissions.length === 0 ? (
            <tr>
              <td colspan="6">Jos nema prijava.</td>
            </tr>
          ) : (
            submissions.map((submission) => (
              <tr>
                <td>{submission.type}</td>
                <td>{submission.name}</td>
                <td>{submission.email}</td>
                <td>{submission.status}</td>
                <td>{new Date(submission.createdAt).toLocaleString("sr-RS")}</td>
                <td>
                  <a href={`${adminConfig.basePath}/submissions/${submission.id}/`}>Detalji</a>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
