---
import { AdminPasswordModal } from "@/components/components/AdminPasswordModal";
import AdminManagedPageForm from "@/components/components/AdminManagedPageForm.astro";
import { localizePath } from "@/features/i18n/locale";
import { getDictionary } from "@/features/i18n/translate";
import { adminAuthService } from "@/features/admin/auth/admin-auth.service";
import { pageContentService } from "@/features/page-content/services/page-content.service";
import type { PageKey } from "@/features/page-content/types/page-content.types";
import { adminConfig } from "@/lib/config/admin";
import type { SiteLocale } from "@/lib/config/site";
import AdminLayout from "@/components/components/AdminLayout.astro";

type SupportedPage = Exclude<PageKey, "home">;

const pageConfig = {
  about: {
    title: "O nama",
    copy: "Uređivanje video sekcije, objašnjenja kabineta, fokus liste i blog bloka.",
  },
  biography: {
    title: "Biografija",
    copy: "Kartice stručnog profila, pristup radu i CTA sekcija.",
  },
  psychotherapy: {
    title: "Pristup",
    copy: "Naslovna sekcija, opseg rada, usluge, zakazivanje i FAQ.",
  },
  scope: {
    title: "Oblast rada",
    copy: "Uvod, fokus blok, blog blok i sve četiri teme sa detail stranicama.",
  },
  pricing: {
    title: "Cena",
    copy: "Tri cenovne kartice i info blokovi ispod njih.",
  },
  appointment: {
    title: "Zakazivanje",
    copy: "Uvod uz formu, formati rada i FAQ blok.",
  },
  faq: {
    title: "Pitanja",
    copy: "FAQ pitanja, slika i blok za zakazivanje.",
  },
} as const satisfies Record<SupportedPage, { title: string; copy: string }>;

const pageParam = Astro.params.page as SupportedPage | undefined;

if (!pageParam || !(pageParam in pageConfig)) {
  return Astro.redirect(`${adminConfig.basePath}/pages/`);
}

const page = pageParam as SupportedPage;
const dictionary = getDictionary("sr-latn");
const authenticated = adminAuthService.isAuthenticated(Astro.cookies);
const localeParam = Astro.url.searchParams.get("locale");
const locale: SiteLocale = localeParam === "sr-cyrl" ? "sr-cyrl" : "sr-latn";
const saved = Astro.url.searchParams.get("saved") === "1";
const error = Astro.url.searchParams.get("error");
const localeLabel = locale === "sr-cyrl" ? "Ćirilica" : "Latinica";
const config = pageConfig[page];
const previewHref = (() => {
  switch (page) {
    case "about":
      return localizePath(locale, "/o-nama/");
    case "biography":
      return localizePath(locale, "/biografija/");
    case "psychotherapy":
      return localizePath(locale, "/psihoterapija/");
    case "scope":
      return localizePath(locale, "/oblast-rada/");
    case "pricing":
      return localizePath(locale, "/cena/");
    case "appointment":
      return localizePath(locale, "/zakazivanje/");
    case "faq":
      return localizePath(locale, "/pitanja/");
  }
})();

const content = authenticated
  ? await (async () => {
      switch (page) {
        case "about":
          return pageContentService.getManagedAboutContent(locale);
        case "biography":
          return pageContentService.getManagedBiographyContent(locale);
        case "psychotherapy":
          return pageContentService.getManagedPsychotherapyContent(locale);
        case "scope":
          return pageContentService.getManagedScopeContent(locale);
        case "pricing":
          return pageContentService.getManagedPricingContent(locale);
        case "appointment":
          return pageContentService.getManagedAppointmentContent(locale);
        case "faq":
          return pageContentService.getManagedFaqContent(locale);
      }
    })()
  : undefined;
---

<AdminLayout title={config.title}>
  {
    authenticated ? (
      <div class="admin-grid">
        {saved ? (
          <p class="admin-status" data-tone="success">
            Izmene stranice su sačuvane.
          </p>
        ) : error === "validation" ? (
          <p class="admin-status" data-tone="error">
            Unos nije validan. Proverite obavezna polja i media URL-ove.
          </p>
        ) : null}

        <div class="card admin-page-header">
          <div class="admin-page-header__content">
            <div>
              <p class="admin-kicker">Page Editing</p>
              <h2>{config.title}</h2>
              <p class="admin-page-header__copy">{config.copy}</p>
            </div>

            <div class="admin-page-header__actions">
              <a
                class:list={["button-secondary", locale === "sr-latn" && "is-active"]}
                href={`${adminConfig.basePath}/pages/${page}/?locale=sr-latn`}
              >
                Latinica
              </a>
              <a
                class:list={["button-secondary", locale === "sr-cyrl" && "is-active"]}
                href={`${adminConfig.basePath}/pages/${page}/?locale=sr-cyrl`}
              >
                Ćirilica
              </a>
            </div>
          </div>
        </div>

        <div class="card admin-meta-card">
          <p>
            Uređujete sadržaj za: <strong style="color: var(--foreground);">{localeLabel}</strong>
          </p>
        </div>

        {content ? (
          <div class="admin-editor-layout" data-admin-page-editor>
            <aside class="admin-editor-layout__aside">
              <div class="card admin-preview-panel">
                <div class="admin-preview-panel__head">
                  <div>
                    <p class="admin-kicker">Live Preview</p>
                    <h3>Javna strana</h3>
                  </div>
                  <a
                    class="button-secondary"
                    href={previewHref}
                    target="_blank"
                    rel="noreferrer"
                    data-admin-preview-open
                  >
                    Otvori stranu
                  </a>
                </div>

                <div class="admin-preview-panel__viewport">
                  <iframe
                    class="admin-preview-panel__frame"
                    src={previewHref}
                    title={`Preview strane ${config.title}`}
                    loading="lazy"
                    data-admin-preview-iframe
                  ></iframe>
                </div>
              </div>

              <div class="card admin-section-nav-card">
                <div class="admin-section-nav-card__head">
                  <p class="admin-kicker">Edit Mode</p>
                  <h3>Sekcije stranice</h3>
                  <p class="section-copy">
                    Uređuje se jedna sekcija u fokusu, dok su ostale sabijene radi preglednosti.
                  </p>
                </div>

                <div class="admin-section-nav" data-admin-section-nav></div>
              </div>
            </aside>

            <div class="admin-editor-layout__form">
              <AdminManagedPageForm
                action={`/api/admin/pages/${page}`}
                page={page}
                content={content}
                locale={locale}
                previewBaseHref={previewHref}
                localeLabel={localeLabel}
              />
            </div>
          </div>
        ) : null}
      </div>
    ) : (
      <div class="page-grid">
        <div class="card admin-intro-card">
          <div class="admin-intro-card__content">
            <p class="admin-kicker">Private Access</p>
            <h2>{dictionary.admin.entry.title}</h2>
            <p class="section-copy">{dictionary.admin.entry.copy}</p>
          </div>
        </div>
        <AdminPasswordModal
          client:load
          returnPath={`${adminConfig.basePath}/pages/${page}/?locale=${locale}`}
        />
      </div>
    )
  }
</AdminLayout>
