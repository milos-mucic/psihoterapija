---
import { AdminPasswordModal } from "@/components/components/AdminPasswordModal";
import { getDictionary } from "@/features/i18n/translate";
import { adminAuthService } from "@/features/admin/auth/admin-auth.service";
import { pageDashboardService } from "@/features/page-content/admin/page-dashboard.service";
import { adminConfig } from "@/lib/config/admin";
import AdminLayout from "@/components/components/AdminLayout.astro";

const dictionary = getDictionary("sr-latn");
const authenticated = adminAuthService.isAuthenticated(Astro.cookies);
const pageOverview = authenticated ? await pageDashboardService.listPages() : [];
const pageStats = authenticated ? pageDashboardService.getStats(pageOverview) : undefined;
---

<AdminLayout title={dictionary.admin.pages.title}>
  {
    authenticated ? (
      <div class="admin-grid">
        <div class="card admin-intro-card">
          <div class="admin-intro-card__content">
            <p class="admin-kicker">Page Studio</p>
            <h2>{dictionary.admin.pages.title}</h2>
            <p class="section-copy">{dictionary.admin.pages.copy}</p>
          </div>

          {pageStats ? (
            <div class="admin-stat-strip">
              <div class="admin-stat-pill">
                <span class="admin-stat-pill__label">Stranice</span>
                <strong>{pageStats.totalPages}</strong>
              </div>
              <div class="admin-stat-pill">
                <span class="admin-stat-pill__label">Needs Translation</span>
                <strong>{pageStats.pagesNeedingTranslation}</strong>
              </div>
              <div class="admin-stat-pill">
                <span class="admin-stat-pill__label">Missing Image</span>
                <strong>{pageStats.pagesWithMissingImages}</strong>
              </div>
              <div class="admin-stat-pill">
                <span class="admin-stat-pill__label">Unpublished</span>
                <strong>{pageStats.pagesWithUnpublishedChanges}</strong>
              </div>
            </div>
          ) : null}
        </div>

        <div class="admin-page-dashboard">
          {pageOverview.map((page) => (
            <article class="card admin-page-card">
              <div class="admin-page-card__head">
                <div>
                  <p class="admin-tile__eyebrow">Page</p>
                  <h3>{page.title}</h3>
                  <p class="admin-tile__copy">{page.copy}</p>
                </div>
              </div>

              <div class="admin-page-card__locale-list">
                {page.locales.map((locale) => (
                  <section class="admin-page-locale">
                    <div class="admin-page-locale__head">
                      <div>
                        <h4>{locale.label}</h4>
                        <p>{locale.updatedAtLabel}</p>
                      </div>
                    </div>

                    <div class="admin-page-locale__actions">
                      <a class="button-secondary" href={locale.editorHref}>
                        Uredi
                      </a>
                      <a
                        class="button-secondary"
                        href={locale.publicHref}
                        target="_blank"
                        rel="noreferrer"
                      >
                        Javna strana
                      </a>
                    </div>
                  </section>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    ) : (
      <div class="page-grid">
        <div class="card admin-intro-card">
          <div class="admin-intro-card__content">
            <p class="admin-kicker">Private Access</p>
            <h2>{dictionary.admin.entry.title}</h2>
            <p class="section-copy">{dictionary.admin.entry.copy}</p>
          </div>
        </div>
        <AdminPasswordModal client:load returnPath={adminConfig.basePath + "/pages/"} />
      </div>
    )
  }
</AdminLayout>
