---
import { getDictionary } from "@/features/i18n/translate";
import { blogService } from "@/features/blog/services/blog.service";
import { adminConfig } from "@/lib/config/admin";
import AdminBlogPostForm from "@/components/components/AdminBlogPostForm.astro";
import AdminLayout from "@/components/components/AdminLayout.astro";

const dictionary = getDictionary("sr-latn");
const { id } = Astro.params;
const post = id ? await blogService.getPostById(id) : undefined;

const params = Astro.url.searchParams;
const created = params.get("created") === "1";
const saved = params.get("saved") === "1";
const error = params.get("error");
---

<AdminLayout title={dictionary.admin.dashboard.blogManagementTitle}>
  <div class="admin-grid">
    {
      created ? (
        <p class="admin-status" data-tone="success">
          {dictionary.admin.blogMessages.created}
        </p>
      ) : saved ? (
        <p class="admin-status" data-tone="success">
          {dictionary.admin.blogMessages.saved}
        </p>
      ) : error === "validation" ? (
        <p class="admin-status" data-tone="error">
          {dictionary.admin.blogMessages.validationError}
        </p>
      ) : error === "slug-conflict" ? (
        <p class="admin-status" data-tone="error">
          {dictionary.admin.blogMessages.slugConflict}
        </p>
      ) : null
    }

    {
      post ? (
        <>
          <div class="card" style="padding: 1.5rem;">
            <div class="page-grid">
              <h2 style="margin: 0;">{post.title}</h2>
              <p class="section-copy">{dictionary.admin.blogEdit.copy}</p>
              <dl style="display: grid; grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr)); gap: 1rem;">
                <div class="card" style="padding: 1rem;">
                  <dt>{dictionary.admin.blogEdit.labels.status}</dt>
                  <dd style="margin: 0.4rem 0 0;">{post.status}</dd>
                </div>
                <div class="card" style="padding: 1rem;">
                  <dt>{dictionary.admin.blogEdit.labels.locale}</dt>
                  <dd style="margin: 0.4rem 0 0;">{post.locale}</dd>
                </div>
                <div class="card" style="padding: 1rem;">
                  <dt>{dictionary.admin.blogEdit.labels.published}</dt>
                  <dd style="margin: 0.4rem 0 0;">
                    {post.publishedAt.toLocaleDateString("sr-RS")}
                  </dd>
                </div>
              </dl>
            </div>
          </div>

          <div class="card" style="padding: 1.5rem;">
            <AdminBlogPostForm
              action={`/api/admin/blog/${post.id}`}
              submitLabel={dictionary.admin.blogEdit.submit}
              post={post}
              labels={dictionary.admin.blogForm.labels}
              placeholders={dictionary.admin.blogForm.placeholders}
              options={dictionary.admin.blogForm.options}
              richText={dictionary.admin.blogForm.richText}
            />
          </div>

          <div
            class="card"
            style="padding: 1.25rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;"
          >
            <p style="margin: 0; color: var(--muted);">{dictionary.admin.blogEdit.deleteHint}</p>
            <form
              id="admin-blog-delete-form"
              action={`/api/admin/blog/${post.id}/delete`}
              method="post"
            >
              <button class="button-ghost" type="button" data-admin-delete-trigger>
                {dictionary.admin.blogEdit.delete}
              </button>
            </form>
          </div>

          <dialog class="admin-confirm-dialog" data-admin-delete-dialog>
            <div class="admin-confirm-dialog__surface">
              <div class="page-grid">
                <h2 class="admin-confirm-dialog__title">
                  {dictionary.admin.blogEdit.deleteConfirm}
                </h2>
                <p class="admin-confirm-dialog__copy">{dictionary.admin.blogEdit.deleteHint}</p>
                <p class="admin-confirm-dialog__meta">{post.title}</p>
              </div>
              <div class="admin-confirm-dialog__actions">
                <button type="button" class="button-secondary" data-admin-delete-cancel>
                  {dictionary.common.cancel}
                </button>
                <button type="button" class="button-primary" data-admin-delete-confirm>
                  {dictionary.admin.blogEdit.delete}
                </button>
              </div>
            </div>
          </dialog>
        </>
      ) : (
        <div class="card" style="padding: 1.5rem;">
          <p style="margin: 0 0 0.75rem;">{dictionary.admin.blogEdit.notFound}</p>
          <a class="button-secondary" href={`${adminConfig.basePath}/blog/`}>
            {dictionary.admin.blogEdit.backToList}
          </a>
        </div>
      )
    }
  </div>
</AdminLayout>

<script is:inline>
  (() => {
    const setupDeleteDialog = () => {
      const dialog = document.querySelector("[data-admin-delete-dialog]");
      const trigger = document.querySelector("[data-admin-delete-trigger]");
      const cancelButton = document.querySelector("[data-admin-delete-cancel]");
      const confirmButton = document.querySelector("[data-admin-delete-confirm]");
      const form = document.getElementById("admin-blog-delete-form");

      if (
        !(dialog instanceof HTMLDialogElement) ||
        !(trigger instanceof HTMLButtonElement) ||
        !(cancelButton instanceof HTMLButtonElement) ||
        !(confirmButton instanceof HTMLButtonElement) ||
        !(form instanceof HTMLFormElement) ||
        dialog.dataset.bound === "true"
      ) {
        return;
      }

      const closeDialog = () => {
        dialog.close();
      };

      trigger.addEventListener("click", () => {
        dialog.showModal();
      });

      cancelButton.addEventListener("click", closeDialog);

      confirmButton.addEventListener("click", () => {
        form.requestSubmit();
        closeDialog();
      });

      dialog.addEventListener("click", (event) => {
        if (event.target === dialog) {
          closeDialog();
        }
      });

      dialog.dataset.bound = "true";
    };

    setupDeleteDialog();
    document.addEventListener("astro:page-load", setupDeleteDialog);
  })();
</script>
