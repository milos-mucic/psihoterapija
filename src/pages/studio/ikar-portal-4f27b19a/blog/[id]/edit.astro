---
import { getDictionary } from "@/features/i18n/translate";
import { blogService } from "@/features/blog/services/blog.service";
import AdminLayout from "@/components/components/AdminLayout.astro";

const dictionary = getDictionary("sr-latn");
const { id } = Astro.params;
const posts = await blogService.listAllPosts();
const post = posts.find((entry) => entry.slug === id);
---

<AdminLayout title={dictionary.admin.dashboard.blogManagementTitle}>
  <div class="card" style="padding: 1.5rem;">
    {
      post ? (
        <div class="page-grid">
          <h2 style="margin: 0;">{post.title}</h2>
          <p class="section-copy">{dictionary.admin.blogEdit.copy}</p>
          <dl style="display: grid; grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr)); gap: 1rem;">
            <div class="card" style="padding: 1rem;">
              <dt>{dictionary.admin.blogEdit.labels.status}</dt>
              <dd style="margin: 0.4rem 0 0;">{post.status}</dd>
            </div>
            <div class="card" style="padding: 1rem;">
              <dt>{dictionary.admin.blogEdit.labels.locale}</dt>
              <dd style="margin: 0.4rem 0 0;">{post.locale}</dd>
            </div>
            <div class="card" style="padding: 1rem;">
              <dt>{dictionary.admin.blogEdit.labels.published}</dt>
              <dd style="margin: 0.4rem 0 0;">{post.publishedAt.toLocaleDateString("sr-RS")}</dd>
            </div>
          </dl>
        </div>
      ) : (
        <p style="margin: 0;">{dictionary.admin.blogEdit.notFound}</p>
      )
    }
  </div>
</AdminLayout>
