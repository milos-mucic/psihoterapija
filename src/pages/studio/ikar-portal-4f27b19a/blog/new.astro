---
import { getDictionary } from "@/features/i18n/translate";
import AdminLayout from "@/components/components/AdminLayout.astro";

const dictionary = getDictionary("sr-latn");
---

<AdminLayout title={dictionary.admin.blogNew.title}>
  <div class="card" style="padding: 1.5rem;">
    <div class="page-grid">
      <h2 style="margin: 0;">{dictionary.admin.blogNew.title}</h2>
      <p class="section-copy">{dictionary.admin.blogNew.copy}</p>
    </div>
  </div>
</AdminLayout>
