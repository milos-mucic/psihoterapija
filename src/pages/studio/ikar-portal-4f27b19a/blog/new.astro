---
import AdminLayout from "@/layouts/AdminLayout.astro";
---

<AdminLayout title="Novi blog post | Ikar admin">
  <div class="card" style="padding: 1.5rem;">
    <div class="page-grid">
      <h2 style="margin: 0;">Novi blog post</h2>
      <p class="section-copy">
        Forma za runtime create/edit je sledeci korak kada prebacimo blog repository sa content
        collections na SQLite ili drugu bazu. Struktura admin rute je spremna da to primi bez
        promene URL arhitekture.
      </p>
    </div>
  </div>
</AdminLayout>
