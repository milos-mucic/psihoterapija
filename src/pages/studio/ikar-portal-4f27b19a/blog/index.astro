---
import { getDictionary } from "@/features/i18n/translate";
import { blogService } from "@/features/blog/services/blog.service";
import { adminConfig } from "@/lib/config/admin";
import AdminLayout from "@/components/components/AdminLayout.astro";

const dictionary = getDictionary("sr-latn");
const posts = await blogService.listAllPosts();
const params = Astro.url.searchParams;
const deleted = params.get("deleted") === "1";
const error = params.get("error");
---

<AdminLayout title={dictionary.admin.dashboard.blogManagementTitle}>
  <div class="admin-grid">
    {
      deleted ? (
        <p class="admin-status" data-tone="success">
          {dictionary.admin.blogMessages.deleted}
        </p>
      ) : error === "not-found" ? (
        <p class="admin-status" data-tone="error">
          {dictionary.admin.blogEdit.notFound}
        </p>
      ) : null
    }

    <div class="card" style="padding: 1.5rem;">
      <div
        style="display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; align-items: center;"
      >
        <div>
          <h2 style="margin: 0;">{dictionary.admin.blogIndex.title}</h2>
          <p style="margin: 0.5rem 0 0; color: var(--muted);">{dictionary.admin.blogIndex.copy}</p>
        </div>
        <a class="button-primary" href={`${adminConfig.basePath}/blog/new/`}
          >{dictionary.admin.blogIndex.newPost}</a
        >
      </div>
    </div>

    <div class="card" style="padding: 1.2rem;">
      <table class="admin-table">
        <thead>
          <tr>
            <th>{dictionary.admin.blogIndex.headers.title}</th>
            <th>{dictionary.admin.blogIndex.headers.locale}</th>
            <th>{dictionary.admin.blogIndex.headers.status}</th>
            <th>{dictionary.admin.blogIndex.headers.date}</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {
            posts.length === 0 ? (
              <tr>
                <td colspan="5">{dictionary.admin.blogIndex.empty}</td>
              </tr>
            ) : (
              posts.map((post) => (
                <tr>
                  <td>{post.title}</td>
                  <td>{post.locale}</td>
                  <td>{post.status}</td>
                  <td>{post.publishedAt.toLocaleDateString("sr-RS")}</td>
                  <td>
                    <a href={`${adminConfig.basePath}/blog/${post.id}/edit/`}>
                      {dictionary.admin.blogIndex.headers.open}
                    </a>
                  </td>
                </tr>
              ))
            )
          }
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
