---
import { blogService } from "@/features/blog/services/blog.service";
import { adminConfig } from "@/lib/config/admin";
import AdminLayout from "@/layouts/AdminLayout.astro";

const posts = await blogService.listAllPosts();
---

<AdminLayout title="Blog management | Ikar admin">
  <div class="admin-grid">
    <div class="card" style="padding: 1.5rem;">
      <div style="display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; align-items: center;">
        <div>
          <h2 style="margin: 0;">Blog postovi</h2>
          <p style="margin: 0.5rem 0 0; color: var(--muted);">Lista trenutno seedovanih tekstova iz content collections sistema.</p>
        </div>
        <a class="button-primary" href={`${adminConfig.basePath}/blog/new/`}>Novi post</a>
      </div>
    </div>

    <div class="card" style="padding: 1.2rem;">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Naslov</th>
            <th>Locale</th>
            <th>Status</th>
            <th>Datum</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {posts.map((post) => (
            <tr>
              <td>{post.title}</td>
              <td>{post.locale}</td>
              <td>{post.status}</td>
              <td>{post.publishedAt.toLocaleDateString("sr-RS")}</td>
              <td>
                <a href={`${adminConfig.basePath}/blog/${post.slug}/edit/`}>Otvori</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
