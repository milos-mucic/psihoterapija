---
import { AdminPasswordModal } from "@/components/components/AdminPasswordModal";
import { getDictionary } from "@/features/i18n/translate";
import { adminAuthService } from "@/features/admin/auth/admin-auth.service";
import { adminConfig } from "@/lib/config/admin";
import AdminLayout from "@/components/components/AdminLayout.astro";

const dictionary = getDictionary("sr-latn");
const authenticated = adminAuthService.isAuthenticated(Astro.cookies);
---

<AdminLayout title={dictionary.meta.admin.dashboardTitle}>
  {
    authenticated ? (
      <div class="admin-grid">
        <div class="card admin-intro-card">
          <div class="admin-intro-card__content">
            <p class="admin-kicker">Ikar Studio</p>
            <h2>{dictionary.admin.dashboard.title}</h2>
            <p class="section-copy">{dictionary.admin.dashboard.copy}</p>
          </div>

          <div class="admin-stat-strip">
            <div class="admin-stat-pill">
              <span class="admin-stat-pill__label">Sadržaj</span>
              <strong>Stranice</strong>
            </div>
            <div class="admin-stat-pill">
              <span class="admin-stat-pill__label">Tok rada</span>
              <strong>Blog</strong>
            </div>
            <div class="admin-stat-pill">
              <span class="admin-stat-pill__label">Upiti</span>
              <strong>Prijave</strong>
            </div>
          </div>
        </div>
        <div class="admin-tile-grid">
          <a class="card admin-tile" href={`${adminConfig.basePath}/pages/`}>
            <p class="admin-tile__eyebrow">Content</p>
            <h3>{dictionary.admin.pages.title}</h3>
            <p class="admin-tile__copy">{dictionary.admin.pages.copy}</p>
            <span class="admin-tile__footer">
              Otvori sekciju
              <span class="admin-tile__arrow">↗</span>
            </span>
          </a>
          <a class="card admin-tile" href={`${adminConfig.basePath}/blog/`}>
            <p class="admin-tile__eyebrow">Publishing</p>
            <h3>{dictionary.admin.dashboard.blogManagementTitle}</h3>
            <p class="admin-tile__copy">{dictionary.admin.dashboard.blogManagementCopy}</p>
            <span class="admin-tile__footer">
              Otvori sekciju
              <span class="admin-tile__arrow">↗</span>
            </span>
          </a>
          <a class="card admin-tile" href={`${adminConfig.basePath}/submissions/`}>
            <p class="admin-tile__eyebrow">Inbox</p>
            <h3>{dictionary.admin.dashboard.submissionsTitle}</h3>
            <p class="admin-tile__copy">{dictionary.admin.dashboard.submissionsCopy}</p>
            <span class="admin-tile__footer">
              Otvori sekciju
              <span class="admin-tile__arrow">↗</span>
            </span>
          </a>
        </div>
      </div>
    ) : (
      <div class="page-grid">
        <div class="card admin-intro-card">
          <div class="admin-intro-card__content">
            <p class="admin-kicker">Private Access</p>
            <h2>{dictionary.admin.entry.title}</h2>
            <p class="section-copy">{dictionary.admin.entry.copy}</p>
          </div>
        </div>
        <AdminPasswordModal client:load returnPath={adminConfig.basePath + "/"} />
      </div>
    )
  }
</AdminLayout>
