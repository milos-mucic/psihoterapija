---
import { AdminPasswordModal } from "@/components/components/AdminPasswordModal";
import { getDictionary } from "@/features/i18n/translate";
import { adminAuthService } from "@/features/admin/auth/admin-auth.service";
import { adminConfig } from "@/lib/config/admin";
import AdminLayout from "@/components/components/AdminLayout.astro";

const dictionary = getDictionary("sr-latn");
const authenticated = adminAuthService.isAuthenticated(Astro.cookies);
---

<AdminLayout title={dictionary.meta.admin.dashboardTitle}>
  {
    authenticated ? (
      <div class="admin-grid">
        <div class="card" style="padding: 1.5rem;">
          <h2>{dictionary.admin.dashboard.title}</h2>
          <p class="section-copy">{dictionary.admin.dashboard.copy}</p>
        </div>
        <div class="page-grid" style="grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));">
          <a class="card" href={`${adminConfig.basePath}/pages/`} style="padding: 1.4rem;">
            <h3>{dictionary.admin.pages.title}</h3>
            <p style="margin: 0; color: var(--muted);">
              {dictionary.admin.pages.copy}
            </p>
          </a>
          <a class="card" href={`${adminConfig.basePath}/blog/`} style="padding: 1.4rem;">
            <h3>{dictionary.admin.dashboard.blogManagementTitle}</h3>
            <p style="margin: 0; color: var(--muted);">
              {dictionary.admin.dashboard.blogManagementCopy}
            </p>
          </a>
          <a class="card" href={`${adminConfig.basePath}/submissions/`} style="padding: 1.4rem;">
            <h3>{dictionary.admin.dashboard.submissionsTitle}</h3>
            <p style="margin: 0; color: var(--muted);">
              {dictionary.admin.dashboard.submissionsCopy}
            </p>
          </a>
        </div>
      </div>
    ) : (
      <div class="page-grid">
        <div class="card" style="padding: 1.5rem;">
          <h2>{dictionary.admin.entry.title}</h2>
          <p class="section-copy">{dictionary.admin.entry.copy}</p>
        </div>
        <AdminPasswordModal client:load returnPath={adminConfig.basePath + "/"} />
      </div>
    )
  }
</AdminLayout>
