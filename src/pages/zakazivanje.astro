---
export const prerender = true;

import AppointmentPage from "@/components/astro/pages/AppointmentPage.astro";
import { getAppointmentPageData } from "@/data/fixtures/public-pages";
import BaseLayout from "@/layouts/BaseLayout.astro";

const locale = "sr-latn";
const content = getAppointmentPageData(locale);
---

<BaseLayout
  title="Zakazivanje | Psihoterapijski kabinet Ikar"
  description={content.banner.description ?? "Zakazite termin u Psihoterapijskom kabinetu Ikar."}
  locale={locale}
  canonicalPath="/zakazivanje/"
>
  <AppointmentPage locale={locale} />
</BaseLayout>
