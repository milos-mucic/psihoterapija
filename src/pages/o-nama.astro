---
export const prerender = true;

import AboutPage from "@/components/astro/pages/AboutPage.astro";
import { getAboutPageData } from "@/data/fixtures/public-pages";
import BaseLayout from "@/layouts/BaseLayout.astro";

const locale = "sr-latn";
const content = getAboutPageData(locale);
---

<BaseLayout
  title="O nama | Psihoterapijski kabinet Ikar"
  description={content.banner.description ?? "Saznajte vise o Psihoterapijskom kabinetu Ikar."}
  locale={locale}
  canonicalPath="/o-nama/"
>
  <AboutPage locale={locale} />
</BaseLayout>
