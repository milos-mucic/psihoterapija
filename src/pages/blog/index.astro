---
export const prerender = true;

import BlogIndexPage from "@/components/pages/BlogIndexPage.astro";
import { blogService } from "@/features/blog/services/blog.service";
import { getDictionary } from "@/features/i18n/translate";
import BaseLayout from "@/components/components/BaseLayout.astro";

const locale = "sr-latn";
const dictionary = getDictionary(locale);
const posts = await blogService.listPublishedPosts(locale);
---

<BaseLayout
  title={dictionary.meta.blog.title}
  description={dictionary.meta.blog.description}
  locale={locale}
  canonicalPath="/blog/"
  appBarTone="dark"
  appBarOverlay={true}
>
  <BlogIndexPage locale={locale} posts={posts} />
</BaseLayout>
