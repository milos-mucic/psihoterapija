---
export async function getStaticPaths() {
  const posts = await blogService.listPublishedPosts("sr-latn");

  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

export const prerender = true;

import { render } from "astro:content";
import { blogService } from "@/features/blog/services/blog.service";
import BlogPostLayout from "@/components/components/BlogPostLayout.astro";

const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing blog slug.");
}

const post = await blogService.getPostBySlug("sr-latn", slug);

if (!post) {
  return Astro.redirect("/blog/");
}

const { Content } = await render(post);
---

<BlogPostLayout
  title={post.data.title}
  description={post.data.excerpt}
  locale="sr-latn"
  canonicalPath={`/blog/${post.slug}/`}
  publishedAt={post.data.publishedAt}
>
  <Content />
</BlogPostLayout>
