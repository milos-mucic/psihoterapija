---
export const prerender = false;

import { blogService } from "@/features/blog/services/blog.service";
import { extractPlainTextFromHtml } from "@/features/blog/utils/rich-text";
import BlogPostLayout from "@/components/components/BlogPostLayout.astro";

const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing blog slug.");
}

const post = await blogService.getPostBySlug("sr-latn", slug);

if (!post || post.status !== "published") {
  return Astro.redirect("/blog/");
}
---

<BlogPostLayout
  title={post.title}
  description={extractPlainTextFromHtml(post.seoDescription ?? post.excerpt)}
  locale="sr-latn"
  canonicalPath={`/blog/${post.slug}/`}
  publishedAt={post.publishedAt}
>
  <div set:html={post.body} />
</BlogPostLayout>
